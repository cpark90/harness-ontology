@prefix ho:    <https://harness-ontology.dev/schema#> .
@prefix sh:    <http://www.w3.org/ns/shacl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .

########################################################################
# SHACL shapes — structural invariants.
# Run against the *reasoned* graph (owlrl materialises subclass +
# inverse + sub-property closure first), so incoming/inverse paths and
# subclass typing are visible.
#
# These shapes encode the anti-orphan / anti-drift guarantees:
#   * every component is wired into at least one harness (no orphans)
#   * every edge points at the correct type (no vocabulary drift)
#   * every harness is complete enough to be composable
########################################################################

#--- A harness must be intentful and complete -------------------------
ho:HarnessShape a sh:NodeShape ;
    sh:targetClass ho:Harness ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:minCount 1 ;
        sh:message "Harness must have a skos:prefLabel (identity, prevents drift/dedup)." ] ;
    sh:property [
        sh:path ho:targetsDomain ;
        sh:minCount 1 ;
        sh:class ho:Domain ;
        sh:message "Harness must target >=1 Domain." ] ;
    sh:property [
        sh:path ho:addressesTask ;
        sh:minCount 1 ;
        sh:class ho:Task ;
        sh:message "Harness must address >=1 Task." ] ;
    sh:property [
        sh:path ho:hasSystemPrompt ;
        sh:minCount 1 ;
        sh:class ho:SystemPrompt ;
        sh:message "Harness must have >=1 SystemPrompt component." ] ;
    sh:property [
        sh:path ho:hasWorkflow ;
        sh:minCount 1 ;
        sh:class ho:Workflow ;
        sh:message "Harness must have >=1 Workflow component." ] .

#--- No orphaned components: each must belong to a harness ------------
# componentOf is the (inferred) inverse of hasComponent and its sub-props.
ho:ComponentConnectivityShape a sh:NodeShape ;
    sh:targetClass ho:HarnessComponent ;
    sh:property [
        sh:path [ sh:inversePath ho:hasComponent ] ;
        sh:minCount 1 ;
        sh:message "Orphaned component: not wired into any Harness via hasComponent (or a sub-property)." ] ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:minCount 1 ;
        sh:message "Component must have a skos:prefLabel." ] .

#--- No orphaned tasks: must be addressed or sit in a taxonomy --------
ho:TaskConnectivityShape a sh:NodeShape ;
    sh:targetClass ho:Task ;
    sh:or (
        [ sh:path [ sh:inversePath ho:addressesTask ] ; sh:minCount 1 ]
        [ sh:path skos:broader ; sh:minCount 1 ]
        [ sh:path [ sh:inversePath skos:broader ] ; sh:minCount 1 ]
    ) ;
    sh:message "Orphaned task: neither addressed by a harness nor placed in the task taxonomy." .

#--- No orphaned capabilities: must be required or provided -----------
ho:CapabilityConnectivityShape a sh:NodeShape ;
    sh:targetClass ho:Capability ;
    sh:or (
        [ sh:path [ sh:inversePath ho:requiresCapability ] ; sh:minCount 1 ]
        [ sh:path [ sh:inversePath ho:providesCapability ] ; sh:minCount 1 ]
    ) ;
    sh:message "Orphaned capability: never required nor provided by anything." .

#--- No orphaned vocabulary: every Concept must connect ---------------
ho:ConceptConnectivityShape a sh:NodeShape ;
    sh:targetClass ho:Concept ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:minCount 1 ;
        sh:message "Concept must have skos:prefLabel." ] ;
    sh:or (
        [ sh:path [ sh:inversePath ho:tagged ] ; sh:minCount 1 ]
        [ sh:path skos:broader ; sh:minCount 1 ]
        [ sh:path [ sh:inversePath skos:broader ] ; sh:minCount 1 ]
        [ sh:path skos:related ; sh:minCount 1 ]
    ) ;
    sh:message "Orphaned concept: tags nothing and is disconnected from the concept taxonomy." .

#--- Typed-edge enforcement (anti-drift) ------------------------------
# OWL rdfs:range does not *constrain*; SHACL does. These stop an edge
# from silently pointing at an untyped or wrong-typed node.
ho:EdgeTypingShape a sh:NodeShape ;
    sh:targetClass ho:Harness ;
    sh:property [ sh:path ho:usesTool ;    sh:class ho:Tool ] ;
    sh:property [ sh:path ho:hasGuardrail ; sh:class ho:Guardrail ] ;
    sh:property [ sh:path ho:appliesPattern ; sh:class ho:DesignPattern ] ;
    sh:property [ sh:path ho:hasExecutionMode ; sh:class ho:ExecutionMode ] ;
    sh:property [ sh:path ho:requiresCapability ; sh:class ho:Capability ] ;
    sh:property [ sh:path ho:constrainedBy ; sh:class ho:Constraint ] .

#--- SystemPrompt must carry text so it is actually usable -----------
ho:SystemPromptShape a sh:NodeShape ;
    sh:targetClass ho:SystemPrompt ;
    sh:property [
        sh:path ho:promptText ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "SystemPrompt must have ho:promptText." ] .

#--- AssemblySection: well-defined position + recognised kind --------
# Per-node half of the total-order guarantee (Stage c): each AssemblySection
# must carry exactly one integer ho:assemblyOrder and exactly one ho:sectionKind
# drawn from the closed set the build emitter recognises. The SET-level
# constraint (no two sections in one harness's assembly sharing an order — i.e.
# the order is TOTAL) is enforced by tools/validate.check_assembly_order, which
# also cross-checks the kinds against the emitter. Together they make an
# ill-defined assembly order a build failure, not a silent code fallback.
ho:AssemblySectionShape a sh:NodeShape ;
    sh:targetClass ho:AssemblySection ;
    sh:property [
        sh:path ho:assemblyOrder ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:integer ;
        sh:message "AssemblySection must have exactly one integer ho:assemblyOrder (a well-defined position)." ] ;
    sh:property [
        sh:path ho:sectionKind ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "overview" "persona" "operating-rules" "process" "model" "roles" "channels" "skills" "execution-mode" "data-flow" "error-handling" "test-scenarios" ) ;
        sh:message "AssemblySection must have exactly one ho:sectionKind from the emitter's closed set (overview/persona/operating-rules/process/model/roles/channels/skills/execution-mode/data-flow/error-handling/test-scenarios)." ] .

#--- Memory: the 3-tier discrimination is enforced, not decorative ---
# Every ho:Memory must be labelled and defined and must declare BOTH its
# read-timing (when it is read relative to execution) and its persistence
# (whether it survives a spawn) from their closed value sets, plus a maturity.
# readScope and activationCondition stay optional (only long-term needs a
# trigger). This makes the firmware/cache/long-term distinction a required,
# well-typed property of any memory tier rather than free-text prose.
ho:MemoryShape a sh:NodeShape ;
    sh:targetClass ho:Memory ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:minCount 1 ;
        sh:message "Memory must have a skos:prefLabel." ] ;
    sh:property [
        sh:path skos:definition ;
        sh:minCount 1 ;
        sh:message "Memory must have a skos:definition." ] ;
    sh:property [
        sh:path ho:memoryReadTiming ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "every-execution" "task-continuous" "conditional" ) ;
        sh:message "Memory must have exactly one ho:memoryReadTiming from the closed set (every-execution/task-continuous/conditional)." ] ;
    sh:property [
        sh:path ho:memoryPersistence ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "durable" "ephemeral" ) ;
        sh:message "Memory must have exactly one ho:memoryPersistence from the closed set (durable/ephemeral)." ] ;
    sh:property [
        sh:path ho:maturity ;
        sh:minCount 1 ;
        sh:message "Memory must have ho:maturity." ] .

#--- TestScenario: a usable behaviour-acceptance fixture ------------
# A TestScenario must be labelled and mature, declare its kind from the
# closed value set, and carry at least one prompt (the request it runs).
# scenarioExpected and scenarioReferences stay optional (a trigger-negative
# fixture may assert only that nothing activates). This keeps the
# normal/error/trigger distinction a required, well-typed property.
ho:TestScenarioShape a sh:NodeShape ;
    sh:targetClass ho:TestScenario ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:minCount 1 ;
        sh:message "TestScenario must have a skos:prefLabel." ] ;
    sh:property [
        sh:path ho:scenarioKind ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "normal" "existing-input" "error" "trigger-positive" "trigger-negative" ) ;
        sh:message "TestScenario must have exactly one ho:scenarioKind from the closed set (normal/existing-input/error/trigger-positive/trigger-negative)." ] ;
    sh:property [
        sh:path ho:scenarioPrompt ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "TestScenario must have >=1 ho:scenarioPrompt (the request it runs)." ] ;
    sh:property [
        sh:path ho:maturity ;
        sh:minCount 1 ;
        sh:message "TestScenario must have ho:maturity." ] .

#--- FailurePolicy: a complete condition->strategy row --------------
# A FailurePolicy row must be labelled and mature and carry BOTH its
# failure condition and its recovery strategy, so an error-handling
# table row is never half-specified.
ho:FailurePolicyShape a sh:NodeShape ;
    sh:targetClass ho:FailurePolicy ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:minCount 1 ;
        sh:message "FailurePolicy must have a skos:prefLabel." ] ;
    sh:property [
        sh:path ho:failureCondition ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "FailurePolicy must have >=1 ho:failureCondition." ] ;
    sh:property [
        sh:path ho:recoveryStrategy ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message "FailurePolicy must have >=1 ho:recoveryStrategy." ] ;
    sh:property [
        sh:path ho:maturity ;
        sh:minCount 1 ;
        sh:message "FailurePolicy must have ho:maturity." ] .

#--- Agent: a well-formed partially-observed distributed node --------
# Every ho:Agent must be labelled and mature, name the Role it compiles
# (>=1 agentRole), hold its ObservationSpace (>=1 agentObservation — its
# cognitive envelope Omega_i is never empty), and declare its cognitive
# capacity (>=1 cognitiveCapacity — the loss-free context bound within
# which its observation must fit). agentFunction stays optional here (an
# agent's action space may be recorded via roleTool). The capacity FIT
# (summed area tokenEstimate <= cognitiveCapacity) is not SHACL-enforceable
# (no aggregation) and is checked by tool/review; this shape enforces the
# structural minimums.
ho:AgentShape a sh:NodeShape ;
    sh:targetClass ho:Agent ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:minCount 1 ;
        sh:message "Agent must have a skos:prefLabel." ] ;
    sh:property [
        sh:path ho:agentRole ;
        sh:minCount 1 ;
        sh:class ho:Role ;
        sh:message "Agent must name >=1 Role via ho:agentRole (its mandate/policy)." ] ;
    sh:property [
        sh:path ho:agentObservation ;
        sh:minCount 1 ;
        sh:class ho:ObservationSpace ;
        sh:message "Agent must hold >=1 ObservationSpace via ho:agentObservation (its cognitive envelope is never empty)." ] ;
    sh:property [
        sh:path ho:cognitiveCapacity ;
        sh:minCount 1 ;
        sh:datatype xsd:integer ;
        sh:message "Agent must declare >=1 ho:cognitiveCapacity (the loss-free context bound)." ] ;
    sh:property [
        sh:path ho:maturity ;
        sh:minCount 1 ;
        sh:message "Agent must have ho:maturity." ] .

#--- ObservationSpace: a well-formed observable envelope (Omega_i) --
# Every ho:ObservationSpace must be labelled and mature, project from a
# GlobalState (>=1 projectsFrom — it is a partial projection of the system
# state) and hold at least one AreaOfObservation (>=1 hasAreaOfObservation
# — something is actually observed). hasAreaOfInterest is enforced by
# ho:AreaOfInterestShape's min-count-free presence via the space (the
# AreaOfInterestShape below requires each interest be well-formed; at least
# one interest is expected but the realized-observation minimum is the hard
# structural floor here). The capacity FIT (summed AreaOfObservation
# tokenEstimate <= the agent's cognitiveCapacity) is not SHACL-enforceable.
ho:ObservationSpaceShape a sh:NodeShape ;
    sh:targetClass ho:ObservationSpace ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:minCount 1 ;
        sh:message "ObservationSpace must have a skos:prefLabel." ] ;
    sh:property [
        sh:path ho:projectsFrom ;
        sh:minCount 1 ;
        sh:class ho:GlobalState ;
        sh:message "ObservationSpace must project from >=1 GlobalState via ho:projectsFrom (it is a partial projection of the system state)." ] ;
    sh:property [
        sh:path ho:hasAreaOfObservation ;
        sh:minCount 1 ;
        sh:class ho:AreaOfObservation ;
        sh:message "ObservationSpace must hold >=1 AreaOfObservation via ho:hasAreaOfObservation (something is actually observed)." ] ;
    sh:property [
        sh:path ho:maturity ;
        sh:minCount 1 ;
        sh:message "ObservationSpace must have ho:maturity." ] .

#--- AreaOfInterest: a well-formed information requirement (intent) --
# Every ho:AreaOfInterest must be labelled and mature and declare its kind
# (internal vs external, from the closed set). No ho:tokenEstimate is
# required — an interest is intent, not consumed input (contrast
# AreaOfObservation, whose realized size is budgeted).
ho:AreaOfInterestShape a sh:NodeShape ;
    sh:targetClass ho:AreaOfInterest ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:minCount 1 ;
        sh:message "AreaOfInterest must have a skos:prefLabel." ] ;
    sh:property [
        sh:path ho:observationKind ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "internal" "external" ) ;
        sh:message "AreaOfInterest must have exactly one ho:observationKind from the closed set (internal/external)." ] ;
    sh:property [
        sh:path ho:maturity ;
        sh:minCount 1 ;
        sh:message "AreaOfInterest must have ho:maturity." ] .

#--- AreaOfObservation: a well-formed realized observation ----------
# Every ho:AreaOfObservation must be labelled and mature, declare its kind
# (internal vs external) and carry a ho:tokenEstimate (the realized size it
# contributes to one inference, summed against the agent's capacity). The
# observes* edges stay SOFT (an area may declare only a file scope or an
# unobserved boundary), so they are not required here.
ho:AreaOfObservationShape a sh:NodeShape ;
    sh:targetClass ho:AreaOfObservation ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:minCount 1 ;
        sh:message "AreaOfObservation must have a skos:prefLabel." ] ;
    sh:property [
        sh:path ho:observationKind ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:in ( "internal" "external" ) ;
        sh:message "AreaOfObservation must have exactly one ho:observationKind from the closed set (internal/external)." ] ;
    sh:property [
        sh:path ho:tokenEstimate ;
        sh:minCount 1 ;
        sh:datatype xsd:integer ;
        sh:message "AreaOfObservation must have >=1 ho:tokenEstimate (realized size contributed to one inference, for capacity fit)." ] ;
    sh:property [
        sh:path ho:maturity ;
        sh:minCount 1 ;
        sh:message "AreaOfObservation must have ho:maturity." ] .

#--- GlobalState: the system-description of a Domain ----------------
# The global state space (the S of a decentralized POMDP) must name the
# Domain it describes (ho:describesDomain, the projection chain's middle
# link) and be labelled and mature. EnvironmentSpace stays shape-free (a
# bare anchor at the top of the chain, like a Domain), so no shape targets
# it.
ho:GlobalStateShape a sh:NodeShape ;
    sh:targetClass ho:GlobalState ;
    sh:property [
        sh:path ho:describesDomain ;
        sh:minCount 1 ;
        sh:class ho:Domain ;
        sh:message "GlobalState must name >=1 Domain via ho:describesDomain (the system it describes is scoped to a Domain)." ] ;
    sh:property [
        sh:path skos:prefLabel ;
        sh:minCount 1 ;
        sh:message "GlobalState must have a skos:prefLabel." ] ;
    sh:property [
        sh:path ho:maturity ;
        sh:minCount 1 ;
        sh:message "GlobalState must have ho:maturity." ] .
