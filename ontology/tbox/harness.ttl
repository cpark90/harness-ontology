@prefix ho:    <https://harness-ontology.dev/schema#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .

########################################################################
# Ontology header (TBox) — agent/LLM harness ontology
#
# Design intent:
#   * Formal OWL 2 semantics = single source of truth. Reasoning + SHACL
#     give connectivity guarantees (kills orphaned nodes) and a controlled
#     vocabulary (kills context drift).
#   * The graph is NEVER loaded whole into an agent. tools/retrieve.py
#     projects a bounded, request-scoped subgraph (kills context rot).
########################################################################

<https://harness-ontology.dev/schema> a owl:Ontology ;
    dct:title "Agent Harness Ontology (schema/TBox)" ;
    owl:versionInfo "0.1.0" ;
    rdfs:comment "Schema for describing, validating and composing agent/LLM harnesses." .

#-----------------------------------------------------------------------
# Core classes
#-----------------------------------------------------------------------

ho:Harness a owl:Class ;
    rdfs:label "Harness" ;
    skos:definition "A complete, runnable agent/LLM configuration: a composition of components (system prompt, tools, guardrails, workflow, model config) aimed at a domain and set of tasks." .

ho:HarnessComponent a owl:Class ;
    rdfs:label "Harness Component" ;
    skos:definition "An abstract reusable building block that a harness is composed of." .

ho:SystemPrompt a owl:Class ;
    rdfs:subClassOf ho:HarnessComponent ;
    rdfs:label "System Prompt" ;
    skos:definition "The persona/instruction text that frames an agent's behaviour." .

ho:Instruction a owl:Class ;
    rdfs:subClassOf ho:HarnessComponent ;
    rdfs:label "Instruction" ;
    skos:definition "A discrete behavioural rule or procedure snippet injected into a harness." .

ho:Tool a owl:Class ;
    rdfs:subClassOf ho:HarnessComponent ;
    rdfs:label "Tool" ;
    skos:definition "An external capability the agent can invoke (function, API, retrieval, code execution)." .

ho:Guardrail a owl:Class ;
    rdfs:subClassOf ho:HarnessComponent ;
    rdfs:label "Guardrail" ;
    skos:definition "A safety/policy constraint that bounds agent behaviour." .

ho:Workflow a owl:Class ;
    rdfs:subClassOf ho:HarnessComponent ;
    rdfs:label "Workflow" ;
    skos:definition "A control-flow strategy (single-shot, ReAct, plan-execute, multi-agent) the harness follows." .

ho:ModelConfig a owl:Class ;
    rdfs:subClassOf ho:HarnessComponent ;
    rdfs:label "Model Config" ;
    skos:definition "Model selection and inference parameters (model id, temperature, token budget)." .

ho:Example a owl:Class ;
    rdfs:subClassOf ho:HarnessComponent ;
    rdfs:label "Example" ;
    skos:definition "A few-shot exemplar demonstrating desired input/output behaviour." .

ho:Role a owl:Class ;
    rdfs:subClassOf ho:HarnessComponent ;
    rdfs:label "Role" ;
    skos:definition "A first-class sub-agent role in a multi-agent harness: it bundles a persona (a SystemPrompt), a least-privilege scope of tools and guardrails it may use, and a memory policy. Choose this over a bare SystemPrompt when the harness dispatches distinct agents (orchestrator/worker/reviewer) whose tool/guardrail boundaries must be captured and materialized as separate .claude/agents/<role>.md files." .

ho:Channel a owl:Class ;
    rdfs:subClassOf ho:HarnessComponent ;
    rdfs:label "Channel" ;
    skos:definition "A coordination/communication channel in a multi-agent harness: the durable conduit over which agent roles (and sometimes the user) exchange status, requests, judgments and results. Choose this to capture HOW roles coordinate — the medium, the participants and the hand-off protocol — as distinct from the roles themselves (ho:Role) or the policies on them (ho:Guardrail). Because sessions can be separate, channels are typically durable files with status markers rather than volatile chat." .

ho:Candidate a owl:Class ;
    rdfs:subClassOf ho:HarnessComponent ;
    rdfs:label "Candidate" ;
    skos:definition "One implementation option for a Tool (a function/tool bound to a concrete file/URL, version and tag). A Tool may carry several Candidates via ho:implementationCandidate; the build projection (tools/materialize.py) applies ho:selectionPolicy — or a supplied lock — to pick exactly one. This is the ODR BIND axis made first-class: the neutral SPEC names the Tool's capability, while WHICH implementation realises it (and its version) lives here, on the recipe side, so the spec stays technology-neutral (INV-1)." .

# Non-component concepts

ho:Capability a owl:Class ;
    rdfs:label "Capability" ;
    skos:definition "An abstract ability (e.g. web-search, code-exec, citation). Harnesses/tasks REQUIRE capabilities; components PROVIDE them. This required/provided pairing drives composition." .

ho:Domain a owl:Class ;
    rdfs:label "Domain" ;
    skos:definition "A problem area a harness targets (coding, research, customer-support, data-analysis)." .

ho:Task a owl:Class ;
    rdfs:label "Task" ;
    skos:definition "A concrete use-case / request pattern a harness addresses." .

ho:DesignPattern a owl:Class ;
    rdfs:label "Design Pattern" ;
    skos:definition "A reusable composition pattern (ReAct, plan-then-execute, orchestrator-workers, reflection)." .

ho:Constraint a owl:Class ;
    rdfs:label "Constraint" ;
    skos:definition "A non-functional requirement or limitation (latency, cost, privacy, offline)." .

# Controlled-vocabulary layer: every taggable term is a skos:Concept.
ho:Concept a owl:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Concept" ;
    skos:definition "A controlled-vocabulary tag used to index and connect nodes." .

#-----------------------------------------------------------------------
# Object properties
#-----------------------------------------------------------------------

# --- composition: Harness -> HarnessComponent -------------------------
ho:hasComponent a owl:ObjectProperty ;
    rdfs:label "has component" ;
    rdfs:domain ho:Harness ;
    rdfs:range ho:HarnessComponent ;
    owl:inverseOf ho:componentOf ;
    owl:propertyChainAxiom ( ho:hasComponent ho:implementationCandidate ) ;
    skos:definition "General composition edge. Specialised sub-properties below carry the component type. The propertyChainAxiom rolls a Tool's implementation Candidates up to the harness that binds the Tool (harness hasComponent tool + tool implementationCandidate cand => harness hasComponent cand), so a Candidate is a reachable, orphan-free HarnessComponent WITHOUT making implementationCandidate a direct sub-property of hasComponent — a direct sub-property would (via rdfs:domain ho:Harness) mistype the Tool subject as a Harness and trip HarnessShape." .

ho:componentOf a owl:ObjectProperty ;
    rdfs:label "component of" ;
    rdfs:domain ho:HarnessComponent ;
    rdfs:range ho:Harness .

ho:hasSystemPrompt a owl:ObjectProperty ;
    rdfs:subPropertyOf ho:hasComponent ;
    rdfs:range ho:SystemPrompt ;
    rdfs:label "has system prompt" .

ho:usesTool a owl:ObjectProperty ;
    rdfs:subPropertyOf ho:hasComponent ;
    rdfs:range ho:Tool ;
    rdfs:label "uses tool" .

ho:hasGuardrail a owl:ObjectProperty ;
    rdfs:subPropertyOf ho:hasComponent ;
    rdfs:range ho:Guardrail ;
    rdfs:label "has guardrail" .

ho:hasWorkflow a owl:ObjectProperty ;
    rdfs:subPropertyOf ho:hasComponent ;
    rdfs:range ho:Workflow ;
    rdfs:label "has workflow" .

ho:usesModel a owl:ObjectProperty ;
    rdfs:subPropertyOf ho:hasComponent ;
    rdfs:range ho:ModelConfig ;
    rdfs:label "uses model" .

ho:hasExample a owl:ObjectProperty ;
    rdfs:subPropertyOf ho:hasComponent ;
    rdfs:range ho:Example ;
    rdfs:label "has example" .

ho:hasInstruction a owl:ObjectProperty ;
    rdfs:subPropertyOf ho:hasComponent ;
    rdfs:range ho:Instruction ;
    rdfs:label "has instruction" .

ho:hasRole a owl:ObjectProperty ;
    rdfs:subPropertyOf ho:hasComponent ;
    rdfs:range ho:Role ;
    rdfs:label "has role" ;
    skos:definition "Binds a first-class sub-agent Role to a (multi-agent) harness. A sub-property of hasComponent so a Role individual is harness-reachable and counted like any other component." .

# --- coordination channels: Harness -> Channel -> participant roles ---
ho:hasChannel a owl:ObjectProperty ;
    rdfs:subPropertyOf ho:hasComponent ;
    rdfs:range ho:Channel ;
    rdfs:label "has channel" ;
    skos:definition "Binds a coordination/communication Channel to a (multi-agent) harness. A sub-property of hasComponent so a Channel individual is harness-reachable and counted like any other component (no bespoke shape needed, mirroring hasRole)." .

ho:channelParticipant a owl:ObjectProperty ;
    rdfs:domain ho:Channel ;
    rdfs:range ho:Role ;
    rdfs:label "channel participant" ;
    skos:definition "An agent Role that is an endpoint on this channel. Points at Roles the harness already binds via hasRole; records WHO coordinates over the channel (the user endpoint, if any, is flagged separately by ho:involvesUser)." .

# --- BIND axis: a Tool's implementation candidates -------------------
ho:implementationCandidate a owl:ObjectProperty ;
    rdfs:domain ho:Tool ;
    rdfs:range ho:Candidate ;
    rdfs:label "implementation candidate" ;
    skos:definition "Associates a Tool with one implementation option (a ho:Candidate). NOT a sub-property of hasComponent (that would mistype the Tool as a Harness via hasComponent's rdfs:domain); instead the ho:hasComponent propertyChainAxiom (hasComponent o implementationCandidate) rolls each Candidate up to the harness that binds the Tool, so the Candidate is a reachable, SHACL-valid component without a bespoke shape. A Tool with several Candidates lets ho:selectionPolicy / a lock choose one at build time (ODR BIND)." .

# --- role scope: Role -> its persona / tool / guardrail boundary ------
ho:rolePersona a owl:ObjectProperty ;
    rdfs:domain ho:Role ;
    rdfs:range ho:SystemPrompt ;
    rdfs:label "role persona" ;
    skos:definition "The SystemPrompt that frames this role's behaviour. The persona is also bound to the harness via hasSystemPrompt so it stays a connected component; rolePersona records WHICH persona belongs to WHICH role for materialization." .

ho:roleTool a owl:ObjectProperty ;
    rdfs:domain ho:Role ;
    rdfs:range ho:Tool ;
    rdfs:label "role tool" ;
    skos:definition "A tool this role is permitted to use — its least-privilege tool scope. Points at Tools the harness already binds via usesTool; the subset here is the boundary written into the role's agent file." .

ho:roleGuardrail a owl:ObjectProperty ;
    rdfs:domain ho:Role ;
    rdfs:range ho:Guardrail ;
    rdfs:label "role guardrail" ;
    skos:definition "A guardrail that applies to this role. Points at Guardrails the harness already binds via hasGuardrail; the subset here is the policy boundary written into the role's agent file." .

# --- targeting / intent ----------------------------------------------
ho:targetsDomain a owl:ObjectProperty ;
    rdfs:domain ho:Harness ;
    rdfs:range ho:Domain ;
    rdfs:label "targets domain" .

ho:addressesTask a owl:ObjectProperty ;
    rdfs:domain ho:Harness ;
    rdfs:range ho:Task ;
    rdfs:label "addresses task" ;
    owl:inverseOf ho:addressedBy .

ho:addressedBy a owl:ObjectProperty ;
    rdfs:domain ho:Task ;
    rdfs:range ho:Harness ;
    rdfs:label "addressed by" .

# --- capability matching (composition engine) -------------------------
ho:requiresCapability a owl:ObjectProperty ;
    rdfs:range ho:Capability ;
    rdfs:label "requires capability" ;
    skos:definition "A harness or task needs this capability to be fulfilled." .

ho:providesCapability a owl:ObjectProperty ;
    rdfs:domain ho:HarnessComponent ;
    rdfs:range ho:Capability ;
    rdfs:label "provides capability" ;
    skos:definition "A component supplies this capability. Composer matches provides->requires." .

# --- patterns & constraints ------------------------------------------
ho:appliesPattern a owl:ObjectProperty ;
    rdfs:domain ho:Harness ;
    rdfs:range ho:DesignPattern ;
    rdfs:label "applies pattern" .

ho:constrainedBy a owl:ObjectProperty ;
    rdfs:range ho:Constraint ;
    rdfs:label "constrained by" .

# --- structural relations --------------------------------------------
ho:dependsOn a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain ho:HarnessComponent ;
    rdfs:range ho:HarnessComponent ;
    rdfs:label "depends on" ;
    skos:definition "A component requires another to function (e.g. a workflow depends on a tool)." .

ho:specializes a owl:ObjectProperty, owl:TransitiveProperty ;
    rdfs:domain ho:Harness ;
    rdfs:range ho:Harness ;
    rdfs:label "specializes" ;
    skos:definition "This harness is a more specific variant of a more general harness." .

ho:derivedFrom a owl:ObjectProperty ;
    rdfs:label "derived from" ;
    skos:definition "Provenance: this node was generated/adapted from another." .

# --- indexing / vocabulary -------------------------------------------
ho:tagged a owl:ObjectProperty ;
    rdfs:range ho:Concept ;
    rdfs:label "tagged" ;
    skos:definition "Associates any node with a controlled-vocabulary concept. Primary retrieval entry edge." .

#-----------------------------------------------------------------------
# Datatype properties
#-----------------------------------------------------------------------

ho:promptText a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "prompt text" ;
    skos:definition "The literal text of a system prompt / instruction / example." .

ho:languageCondition a owl:DatatypeProperty ;
    rdfs:domain ho:Guardrail ;
    rdfs:range xsd:string ;
    rdfs:label "language condition" ;
    skos:definition "A specific language rule the guardrail enforces — which language applies to which artifact class (prose vs terms vs code/identifiers/commits). One item per artifact class; enriches a language guardrail without splitting it into separate nodes." .

ho:artifactTemplate a owl:DatatypeProperty ;
    rdfs:domain ho:HarnessComponent ;
    rdfs:range xsd:string ;
    rdfs:label "artifact template" ;
    skos:definition "Repo-relative path to a template fragment that materialize.py renders for this component's section; absent => render from graph data. The build projection (tools/materialize.py) reads the file and substitutes the node's graph data ({{prefLabel}}/{{promptText}}); the READ projection (retrieve.py) ignores it." .

ho:implementationRef a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "implementation ref" ;
    skos:definition "Path (repo-relative or absolute) or URL to a real implementation file. Carried by a ho:Candidate (which file this option resolves to) OR directly by a ho:Tool as a degenerate single-candidate. Precedence at build time: explicit ho:implementationCandidate list > a direct ho:implementationRef on the Tool > stub. On build, materialize.py copies the resolved file into tools/<basename>; if unresolvable it writes a tools/<basename>.ref stub. Build-only, like artifactTemplate; retrieve.py ignores it. (No rdfs:domain: it applies to both Tool and Candidate; a Tool domain would, via prp-dom, mistype a Candidate carrying it as a Tool.)" .

ho:candidateVersion a owl:DatatypeProperty ;
    rdfs:domain ho:Candidate ;
    rdfs:range xsd:string ;
    rdfs:label "candidate version" ;
    skos:definition "The version string of this implementation candidate (e.g. \"1.4.0\"). Recorded in the lock so a past build is reproducible, and used as a deterministic tie-breaker (higher version wins) when a selection policy ranks candidates of the same tag." .

ho:candidateTag a owl:DatatypeProperty ;
    rdfs:domain ho:Candidate ;
    rdfs:range xsd:string ;
    rdfs:label "candidate tag" ;
    skos:definition "A stability/family label for this candidate (e.g. \"stable\", \"latest\", or a family name). ho:selectionPolicy interprets these: \"latest-stable\" prefers the \"stable\" tag, \"conservative\" the most cautious, \"pinned:<tag>\" selects exactly this tag." .

ho:selectionPolicy a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "selection policy" ;
    skos:definition "How the build projection picks among a Tool's implementation Candidates when no lock is supplied. Carried by a Tool (per-tool policy) or a Harness (default for all its tools); a Tool-level policy overrides the Harness default. Recognised values: \"latest-stable\" (prefer tag=stable, then highest candidateVersion), \"conservative\" (prefer tag=stable, then LOWEST candidateVersion), \"pinned:<tag>\" (require exactly that tag). Selection is total and deterministic (ties broken by candidateVersion then candidate IRI) so (spec + policy) reproduces the same choice. No rdfs:domain: it applies to Tool or Harness, and a single conjunctive domain would demand both." .

ho:roleMemoryPolicy a owl:DatatypeProperty ;
    rdfs:domain ho:Role ;
    rdfs:range xsd:string ;
    rdfs:label "role memory policy" ;
    skos:definition "The role's memory/state discipline as a short directive (e.g. which memory directory it reads/writes, read-only vs read-write scope). Rendered into the role's .claude/agents/<role>.md by materialize.py." .

ho:userFacing a owl:DatatypeProperty ;
    rdfs:domain ho:Role ;
    rdfs:range xsd:boolean ;
    rdfs:label "user facing" ;
    skos:definition "True if the role communicates with the user; false for a work-performing agent invoked only via dispatch." .

ho:involvesUser a owl:DatatypeProperty ;
    rdfs:domain ho:Channel ;
    rdfs:range xsd:boolean ;
    rdfs:label "involves user" ;
    skos:definition "True if the user is an endpoint on this channel (an agent<->user channel); false for a channel purely between agent roles." .

ho:channelMedium a owl:DatatypeProperty ;
    rdfs:domain ho:Channel ;
    rdfs:range xsd:string ;
    rdfs:label "channel medium" ;
    skos:definition "The concrete conduit and hand-off mechanism of the channel as a short directive (e.g. \"durable file channel + status markers\", \"dispatch (subagent spawn)\"). Records HOW coordination is carried so it survives separate sessions and is materialized into the harness's coordination docs." .

ho:scaffold a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "scaffold" ;
    skos:definition "Repo-relative path to a standard-document / docs-tree fragment attached to a Harness (or Domain). materialize.py renders each fragment into the output tree, mirroring its path with a leading 'scaffold/' segment stripped (so scaffold/docs/x.md => docs/x.md, scaffold/STANDARD.md => STANDARD.md). Distinct from artifactTemplate — that renders a COMPONENT's CLAUDE.md section and its domain (ho:HarnessComponent) would, under OWL RL, mistype a Harness/Domain as a component (tripping the orphan shape); scaffold carries no rdfs:domain and emits standalone files, not sections." .

ho:tokenEstimate a owl:DatatypeProperty ;
    rdfs:range xsd:integer ;
    rdfs:label "token estimate" ;
    skos:definition "Approx. token cost of this node's text. Used by the projector to stay within budget (context-rot defense)." .

ho:salience a owl:DatatypeProperty ;
    rdfs:range xsd:decimal ;
    rdfs:label "salience" ;
    skos:definition "0..1 prior importance, used to rank nodes during bounded traversal." .

ho:maturity a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:label "maturity" ;
    skos:definition "Lifecycle status: draft | reviewed | stable | deprecated." .
