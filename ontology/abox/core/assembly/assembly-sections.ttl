@prefix ho:    <https://harness-ontology.dev/schema#> .
@prefix id:    <https://harness-ontology.dev/id/core/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .

# Core data unit -- Assembly-section partition of the `core` domain (split out
# of the harnesses unit: the central DEFAULT assembly order of the materialized
# document). Imports the central TBox only; cross-unit references (the
# h-multiagent harness binding these via ho:hasAssemblySection) resolve in the
# root union (docs/federation-design.md D1, ONTOLOGYSTYLE 4).
<https://harness-ontology.dev/data/core/assembly-sections> a owl:Ontology ;
    owl:imports <https://harness-ontology.dev/schema> .

#===================== ASSEMBLY SECTIONS (central default order) =======
# The central DEFAULT assembly order of the materialized CLAUDE.md document,
# as graph SPEC (Stage c of finer-harness-decomposition-assembly). HOW a
# harness's parts are assembled into the final document -- which sections, in
# what sequence -- was previously hardcoded in tools/materialize.py; it now
# lives here so it is inspectable and per-harness redefinable, and materialize
# only READS this order to sequence the sections it emits. This set is attached
# to the neutral base template id:h-multiagent (making the sections reachable
# and giving the template its order) and serves as the DEFAULT for every harness
# that declares no ho:hasAssemblySection of its own -- so existing harnesses'
# emitted documents are byte-identical to the former fixed order. The order MUST
# be total and well-defined (each ho:assemblyOrder unique, each ho:sectionKind
# recognised by the emitter) or the build fails loudly (determinism, INV-2). A
# harness MAY declare its own set to override the order (part-to-part assembly
# made explicit). The conditional kinds (roles/channels/skills, plus the
# run-behaviour sections 9..12 below) stay in the order but emit nothing when the
# harness has no such parts, exactly as before.
id:as-overview a ho:AssemblySection ;
    skos:prefLabel "Assembly: overview section" ;
    skos:definition "Positions the document's opening overview (the harness prefLabel heading and its definition) first. Choose to keep the assembled CLAUDE.md led by WHAT the harness is before any component detail." ;
    ho:sectionKind "overview" ; ho:assemblyOrder 1 ; ho:tokenEstimate 18 ; ho:maturity "draft" .

id:as-persona a ho:AssemblySection ;
    skos:prefLabel "Assembly: persona section" ;
    skos:definition "Positions the Persona section (rendered from the harness's hasSystemPrompt, per-role personas excluded) second, right after the overview." ;
    ho:sectionKind "persona" ; ho:assemblyOrder 2 ; ho:tokenEstimate 18 ; ho:maturity "draft" .

id:as-operating-rules a ho:AssemblySection ;
    skos:prefLabel "Assembly: operating-rules section" ;
    skos:definition "Positions the Operating rules section (rendered from the harness's hasGuardrail policies) third, framing behaviour before the process is described." ;
    ho:sectionKind "operating-rules" ; ho:assemblyOrder 3 ; ho:tokenEstimate 18 ; ho:maturity "draft" .

id:as-process a ho:AssemblySection ;
    skos:prefLabel "Assembly: process section" ;
    skos:definition "Positions the Process section (rendered from hasWorkflow steps and appliesPattern) fourth, describing HOW the agent works." ;
    ho:sectionKind "process" ; ho:assemblyOrder 4 ; ho:tokenEstimate 18 ; ho:maturity "draft" .

id:as-model a ho:AssemblySection ;
    skos:prefLabel "Assembly: model section" ;
    skos:definition "Positions the Model section (rendered from usesModel) fifth, after the behavioural spec." ;
    ho:sectionKind "model" ; ho:assemblyOrder 5 ; ho:tokenEstimate 16 ; ho:maturity "draft" .

id:as-roles a ho:AssemblySection ;
    skos:prefLabel "Assembly: roles section" ;
    skos:definition "Positions the Roles section (rendered from hasRole) sixth. A conditional section: emits nothing when the harness dispatches no sub-agent roles." ;
    ho:sectionKind "roles" ; ho:assemblyOrder 6 ; ho:tokenEstimate 18 ; ho:maturity "draft" .

id:as-channels a ho:AssemblySection ;
    skos:prefLabel "Assembly: channels section" ;
    skos:definition "Positions the Coordination channels section (rendered from hasChannel) seventh. A conditional section: emits nothing when the harness declares no channels." ;
    ho:sectionKind "channels" ; ho:assemblyOrder 7 ; ho:tokenEstimate 18 ; ho:maturity "draft" .

id:as-skills a ho:AssemblySection ;
    skos:prefLabel "Assembly: skills section" ;
    skos:definition "Positions the Skills section (rendered from hasInstruction) eighth, closing the compositional half of the document (the parts the harness is made of)." ;
    ho:sectionKind "skills" ; ho:assemblyOrder 8 ; ho:tokenEstimate 18 ; ho:maturity "draft" .

#===================== RUN-BEHAVIOUR SECTIONS (9..12) ==================
# The second half of the default order: where sections 1-8 describe WHAT the
# harness is made of, these describe how an assembled harness RUNS and how it is
# judged -- the runtime execution mode, the error-handling table and the
# behaviour-acceptance fixtures. They sit after the compositional sections
# because each one qualifies parts already introduced above rather than adding
# new ones. All are CONDITIONAL, exactly like roles/channels/skills: a harness
# with no such part emits nothing for them, so a harness that carries none of
# these parts materializes exactly the document it did before this extension.
#
# The one section that is NOT inert for the base template is "data-flow" (order
# 10): id:h-multiagent binds the workflow carrying the central Deliverable DAG,
# so the section DOES emit for it and its materialized document gains a Data flow
# section. That change is intended, not churn -- this extension surfaces data the
# graph already held (ho:stepProduces / ho:stepConsumes) but the emitter never
# rendered; suppressing it would defeat the section's purpose.
id:as-execution-mode a ho:AssemblySection ;
    skos:prefLabel "Assembly: execution-mode section" ;
    skos:definition "Positions the Execution mode section (the runtime coordination topology, rendered from the harness's appliesPattern picks that are tagged as execution modes) ninth, right after the compositional sections: it qualifies HOW the workflow, roles and channels already described are spawned and coordinated at run time rather than introducing new parts. A conditional section: emits nothing when the harness applies no execution-mode pattern." ;
    ho:sectionKind "execution-mode" ; ho:assemblyOrder 9 ; ho:tokenEstimate 24 ; ho:maturity "draft" .

id:as-data-flow a ho:AssemblySection ;
    skos:prefLabel "Assembly: data-flow section" ;
    skos:definition "Positions the Data flow section (the Deliverable DAG recovered by joining the workflow steps' stepProduces to their stepConsumes) tenth, directly after the execution mode: the reader has just been told in what topology the steps run, and this says which named artifact each step emits and which step reads it -- the flow the step order alone cannot express. A conditional section: emits nothing when the harness's steps name no deliverable." ;
    ho:sectionKind "data-flow" ; ho:assemblyOrder 10 ; ho:tokenEstimate 26 ; ho:maturity "draft" .

id:as-error-handling a ho:AssemblySection ;
    skos:prefLabel "Assembly: error-handling section" ;
    skos:definition "Positions the Error handling section (the failure-condition to recovery-strategy rows rendered from hasFailurePolicy) eleventh, after the sections that state what the harness does and how it runs, because it answers what happens when those steps do NOT succeed. A conditional section: emits nothing when the harness declares no failure policy." ;
    ho:sectionKind "error-handling" ; ho:assemblyOrder 11 ; ho:tokenEstimate 22 ; ho:maturity "draft" .

id:as-test-scenarios a ho:AssemblySection ;
    skos:prefLabel "Assembly: test-scenarios section" ;
    skos:definition "Positions the Test scenarios section (the behaviour-acceptance fixtures rendered from hasTestScenario) last, as the acceptance appendix the assembled harness is checked against once its whole specification has been read. A conditional section: emits nothing when the harness carries no test scenario." ;
    ho:sectionKind "test-scenarios" ; ho:assemblyOrder 12 ; ho:tokenEstimate 22 ; ho:maturity "draft" .
