@prefix ho:    <https://harness-ontology.dev/schema#> .
@prefix id:    <https://harness-ontology.dev/id/core/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .

# Core data unit -- Harness partition of the `core` domain. Imports the
# central TBox only; cross-unit references resolve in the root union
# (docs/federation-design.md D1, ONTOLOGYSTYLE 4).
<https://harness-ontology.dev/data/core/harnesses> a owl:Ontology ;
    owl:imports <https://harness-ontology.dev/schema> .

########################################################################
# Seed ABox — three example harnesses that deliberately SHARE
# components (vector-retriever, cite-sources, opus model) and vocabulary
# (information-retrieval), so the graph is connected and retrieval has
# something interesting to traverse.
########################################################################

#===================== HARNESSES =======================================

id:h-coding a ho:Harness ;
    skos:prefLabel "Autonomous coding agent" ; skos:altLabel "coding harness" ;
    skos:definition "An autonomous agent that fixes bugs and reviews code with shell + editor tools." ;
    ho:targetsDomain id:dom-coding ;
    ho:addressesTask id:task-bugfix, id:task-codereview ;
    ho:hasSystemPrompt id:sp-coding ;
    ho:usesTool id:tool-shell, id:tool-editor ;
    ho:hasWorkflow id:wf-react ;
    ho:hasGuardrail id:gr-nodestruct, id:gr-lang ;
    ho:usesModel id:mc-opus ;
    ho:appliesPattern id:pat-react ;
    ho:requiresCapability id:cap-codeexec, id:cap-fileedit ;
    ho:tagged id:c-softeng, id:c-debugging, id:c-autonomy ;
    ho:maturity "stable" .

id:h-research a ho:Harness ;
    skos:prefLabel "Research synthesis agent" ; skos:altLabel "research harness" ;
    skos:definition "A plan-execute agent that surveys sources and writes cited syntheses." ;
    ho:targetsDomain id:dom-research ;
    ho:addressesTask id:task-litreview ;
    ho:hasSystemPrompt id:sp-research ;
    ho:usesTool id:tool-websearch, id:tool-retriever ;
    ho:hasWorkflow id:wf-planexec ;
    ho:hasGuardrail id:gr-cite, id:gr-lang ;
    ho:usesModel id:mc-opus ;
    ho:appliesPattern id:pat-planexec ;
    ho:requiresCapability id:cap-websearch, id:cap-retrieval, id:cap-citation ;
    ho:tagged id:c-inforetrieval, id:c-summarization ;
    ho:maturity "reviewed" .

id:h-support a ho:Harness ;
    skos:prefLabel "Support triage agent" ; skos:altLabel "support harness" ;
    skos:definition "A low-latency single-shot agent that triages support tickets with retrieval." ;
    ho:targetsDomain id:dom-support ;
    ho:addressesTask id:task-triage ;
    ho:hasSystemPrompt id:sp-support ;
    ho:usesTool id:tool-retriever ;
    ho:hasWorkflow id:wf-singleshot ;
    ho:hasGuardrail id:gr-cite, id:gr-lang ;
    ho:usesModel id:mc-sonnet ;
    ho:appliesPattern id:pat-reflection ;
    ho:requiresCapability id:cap-retrieval ;
    ho:constrainedBy id:con-lowlatency ;
    ho:tagged id:c-inforetrieval ;
    ho:specializes id:h-research ;
    ho:maturity "reviewed" .

########################################################################
# Reusable parts decomposed from harness governance docs
#
# Neutral, domain-INDEPENDENT building blocks extracted from the design /
# multi-agent governance methodology (CLAUDE.md, CODESTYLE.md,
# DESIGN_HARNESS_STANDARD.md). These are library PARTS: generalised
# guardrail policies, an orchestration pattern/workflow and a methodical
# persona that any future harness can assemble. The h-multiagent harness
# below only exists to wire the parts (anti-orphan) and stands as a neutral
# template — it names no specific problem domain, tool or technology.
########################################################################

#===================== HARNESSES =======================================

id:h-multiagent a ho:Harness ;
    skos:prefLabel "Multi-agent orchestration harness" ; skos:altLabel "orchestrator-workers harness" ;
    skos:definition "A neutral, domain-independent harness that assembles the reusable governance parts decomposed from harness governance docs: an orchestrator plans and dispatches node-scoped briefs to specialised workers (author / verify / inspect) under least-privilege, with traceability, verify-then-proceed and escalation guardrails. Its PURPOSE is to make each role's agent perform its role clearly: it composes, per role, the role's scope of tools and guardrails (ho:roleTool / ho:roleGuardrail), its memory discipline and (where present) its user-facing stance, plus the coordination channels the roles exchange work over — so every dispatched agent has an unambiguous mandate. Use as a template for any structured, multi-agent design or authoring workflow." ;
    ho:targetsDomain id:dom-design ;
    ho:addressesTask id:task-architecture, id:task-designdecision ;
    ho:hasSystemPrompt id:sp-methodical ;
    ho:usesTool id:tool-shell, id:tool-editor, id:tool-websearch, id:tool-retriever ;
    ho:hasWorkflow id:wf-multiagent, id:wf-compose-harness ;
    ho:hasGuardrail id:gr-lang, id:gr-verify-proceed, id:gr-design-for-loss, id:gr-traceability,
        id:gr-grounding, id:gr-no-arbitrary-decision, id:gr-least-privilege, id:gr-report-over-prompt,
        id:gr-controlled-vocabulary, id:gr-root-cause, id:gr-simplicity, id:gr-bounded-context,
        id:gr-dispatch-execution, id:gr-delegated-orchestration, id:gr-structural-coverage, id:gr-reuse-first ;
    ho:usesModel id:mc-opus ;
    ho:hasRole id:role-orchestrator, id:role-inspection, id:role-developer, id:role-research,
        id:role-inspection-worker, id:role-vnv, id:role-design ;
    ho:hasChannel id:chan-agent-user, id:chan-orchestrator-inspection, id:chan-dispatch ;
    ho:hasMemory id:mem-firmware, id:mem-cache, id:mem-longterm ;
    ho:hasAgent id:agent-orchestrator, id:agent-developer, id:agent-vnv, id:agent-inspection,
        id:agent-synthesizer ;
    ho:hasGlobalState id:global-state ;
    ho:hasAssemblySection id:as-overview, id:as-persona, id:as-operating-rules, id:as-process,
        id:as-model, id:as-roles, id:as-channels, id:as-skills, id:as-execution-mode,
        id:as-data-flow, id:as-error-handling, id:as-test-scenarios ;
    ho:appliesPattern id:pat-orchestrator-workers, id:pat-ontology-composition ;
    ho:requiresCapability id:cap-orchestration, id:cap-traceability, id:cap-codeexec, id:cap-fileedit ;
    ho:tagged id:c-design, id:c-multiagent, id:c-traceability ;
    ho:maturity "draft" .

# The peer-mesh counterpart of id:h-multiagent: a neutral, domain-independent
# template that exists to WIRE the peer-mesh coordination parts (anti-orphan) and
# to make coordination topology an explicit, selectable dimension. Where
# id:h-multiagent stays the orchestrator-workers DEFAULT doctrine (central
# dispatch), this one demonstrates the alternative — peers coordinate directly
# over id:chan-peer with no central-only dispatcher — by declaring
# ho:appliesPattern id:pat-peer-mesh plus the matching channel. A recipe that
# needs peer-mesh derives from this; new topologies are added the same way (new
# DesignPattern + Channel + a host harness) without disturbing either existing
# one. It reuses central parts by IRI and names no specific domain/tool/tech.
id:h-peer-mesh a ho:Harness ;
    skos:prefLabel "Peer-mesh coordination harness" ; skos:altLabel "peer-mesh harness" ;
    skos:definition "A neutral, domain-independent template harness demonstrating the peer-mesh coordination methodology as the selectable alternative to orchestrator-workers: peer worker roles coordinate DIRECTLY over a message mesh (id:chan-peer) rather than through a central-only dispatcher. It exists to wire the peer-mesh parts (anti-orphan) and to make coordination topology a pluggable dimension — a harness picks its methodology via ho:appliesPattern plus the matching ho:Channel, and new topologies are added as new DesignPattern + Channel without disturbing the orchestrator-workers default (id:h-multiagent). Names no specific problem domain, tool or technology." ;
    ho:targetsDomain id:dom-design ;
    ho:addressesTask id:task-designdecision ;
    ho:hasSystemPrompt id:sp-methodical ;
    ho:usesTool id:tool-editor ;
    ho:hasWorkflow id:wf-multiagent ;
    ho:hasGuardrail id:gr-lang, id:gr-report-over-prompt, id:gr-least-privilege ;
    ho:usesModel id:mc-opus ;
    ho:hasRole id:role-developer, id:role-vnv, id:role-research, id:role-design ;
    ho:hasChannel id:chan-peer ;
    ho:appliesPattern id:pat-peer-mesh ;
    ho:tagged id:c-multiagent, id:c-design ;
    ho:derivedFrom id:h-multiagent ;
    ho:maturity "draft" .

# The central-library host of the recurring neutral parts promoted for reuse
# across the corpus of multi-agent harnesses: the terminal convergence gate
# (id:role-synthesizer, providing id:cap-synthesis), the shared file workspace
# roles hand off deliverables over (id:chan-workspace), and the recurring
# guardrails (structured output, scale modes, graceful fallback). Like
# id:h-peer-mesh, this neutral template exists purely to WIRE those parts
# (anti-orphan) -- it is a library carrier, not a domain pilot, and names no
# specific problem domain, tool or technology. The new parts live here rather
# than on id:h-multiagent so binding them does NOT change id:h-multiagent's
# materialized CLAUDE.md (byte-identical stability). It requires id:cap-synthesis
# and its bound id:role-synthesizer provides it, so capability satisfaction holds
# internally. Reuses central parts by IRI (sp-methodical / wf-multiagent /
# tool-editor / mc-opus / dom-design / task-designdecision).
id:h-workspace-synthesis a ho:Harness ;
    skos:prefLabel "Workspace-synthesis harness" ; skos:altLabel "convergence-gate library host" ;
    skos:definition "A neutral, domain-independent template that wires the recurring central-library parts a multi-agent worker team reuses: worker roles hand off deliverables over a shared file workspace (id:chan-workspace), each deliverable follows a structured-output template and the run scales to the request and degrades gracefully on failure (the recurring guardrails), and a terminal synthesizer gate (id:role-synthesizer) cross-checks every contribution and compiles the integrated final result (providing id:cap-synthesis, which this harness requires). It exists to make those parts connected, reusable components (anti-orphan) and stands as a neutral template -- it names no specific problem domain, tool or technology. Derives from id:h-multiagent and reuses central parts by IRI." ;
    ho:targetsDomain id:dom-design ;
    ho:addressesTask id:task-designdecision ;
    ho:hasSystemPrompt id:sp-methodical ;
    ho:usesTool id:tool-editor ;
    ho:hasWorkflow id:wf-multiagent ;
    ho:hasGuardrail id:gr-lang, id:gr-structured-output, id:gr-scale-modes, id:gr-graceful-fallback ;
    ho:usesModel id:mc-opus ;
    ho:hasRole id:role-developer, id:role-research, id:role-inspection-worker,
        id:role-vnv, id:role-design, id:role-synthesizer ;
    ho:hasChannel id:chan-workspace ;
    ho:requiresCapability id:cap-synthesis ;
    ho:tagged id:c-multiagent, id:c-design, id:c-synthesis ;
    ho:derivedFrom id:h-multiagent ;
    ho:maturity "draft" .

# The central-library host of the harness-authoring METHODOLOGY parts decomposed
# from the revfactory/harness methodology (a meta-harness for building harnesses):
# the coordination-complexity guardrails (delegation depth, no nested teams,
# single active team, bottleneck avoidance, flatten hierarchy, bounded iteration),
# the authoring/verification/model-governance guardrails (integration coherence,
# discriminating evaluation, single responsibility, generalize-not-overfit,
# absolute workspace paths, well-formed skill, opus required) and the task-board
# coordination channel (id:chan-task-board). Like id:h-workspace-synthesis and
# id:h-peer-mesh, this neutral template exists purely to WIRE those parts
# (anti-orphan): they live here rather than on id:h-multiagent so binding them
# does NOT change id:h-multiagent's materialized CLAUDE.md (byte-identical
# stability). It is a library carrier, not a domain pilot, and names no specific
# problem domain, tool or technology. Reuses central parts by IRI (sp-methodical /
# wf-multiagent / tool-editor / tool-shell / mc-opus / dom-design /
# task-designdecision). It now also carries the meta-workflows whose SUBJECT is a
# harness -- the lifecycle loop (id:wf-harness-evolution) and the verification
# pass (id:wf-verify-harness) -- together with the neutral behaviour-acceptance
# fixtures and error-handling rows they judge with; those belong to the
# methodology, not to the general multi-agent template, and hosting them here
# again leaves id:h-multiagent's materialized document byte-identical. Those
# fixtures and rows now reach the emitted document through the run-behaviour
# assembly sections (error-handling / test-scenarios, plus execution-mode and
# data-flow) carried by the central default order. Still missing (later wave):
# the cap-skill requirement.
id:h-harness-factory a ho:Harness ;
    skos:prefLabel "Harness-factory harness" ; skos:altLabel "harness-authoring methodology host" ;
    skos:definition "A neutral, domain-independent template that wires the harness-authoring methodology parts: the guardrails that bound multi-agent orchestration complexity and govern faithful authoring, verification and model selection, plus the shared task-board channel (id:chan-task-board) over which workers claim and report tasks. It is a meta-harness -- its subject is the methodology of composing, verifying and evolving harnesses themselves. Like id:h-workspace-synthesis it exists to make those parts connected, reusable components (anti-orphan) and stands as a neutral template -- the parts live here rather than on id:h-multiagent so binding them leaves that harness's materialized document byte-identical. It names no specific problem domain, tool or technology, derives from id:h-multiagent and reuses central parts by IRI." ;
    ho:targetsDomain id:dom-design ;
    ho:addressesTask id:task-designdecision ;
    ho:hasSystemPrompt id:sp-methodical ;
    ho:usesTool id:tool-editor, id:tool-shell ;
    ho:hasWorkflow id:wf-multiagent, id:wf-harness-evolution, id:wf-verify-harness ;
    ho:hasGuardrail id:gr-lang, id:gr-depth-limit, id:gr-no-nested-teams, id:gr-single-active-team,
        id:gr-bottleneck-avoidance, id:gr-flatten-hierarchy, id:gr-bounded-iteration,
        id:gr-integration-coherence, id:gr-discriminating-eval, id:gr-single-responsibility,
        id:gr-generalize-not-overfit, id:gr-absolute-paths, id:gr-well-formed-skill, id:gr-opus-required ;
    ho:usesModel id:mc-opus ;
    ho:hasChannel id:chan-task-board ;
    ho:hasTestScenario id:scn-compose-smoke, id:scn-trigger-near-miss ;
    ho:hasFailurePolicy id:fp-dispatch-timeout, id:fp-validation-fail ;
    ho:appliesPattern id:pat-orchestrator-workers ;
    ho:requiresCapability id:cap-orchestration, id:cap-fileedit, id:cap-codeexec ;
    ho:tagged id:c-multiagent, id:c-composition, id:c-agent-methodology ;
    ho:derivedFrom id:h-multiagent ;
    ho:maturity "draft" .
