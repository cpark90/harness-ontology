@prefix ho:    <https://harness-ontology.dev/schema#> .
@prefix id:    <https://harness-ontology.dev/id/core/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .

# Core data unit -- Observation partition of the `core` domain (split out of
# the roles unit: the per-agent observation spaces, areas of interest and
# areas of observation). Imports the central TBox only; cross-unit references
# (each agent's ho:agentObservation, the channels/memory/roles the areas
# observe, id:global-state each space projects from) resolve in the root union
# (docs/federation-design.md D1, ONTOLOGYSTYLE 4).
<https://harness-ontology.dev/data/core/observation> a owl:Ontology ;
    owl:imports <https://harness-ontology.dev/schema> .

########################################################################
# Observation spaces — the per-agent observable envelopes (Omega_i). Each
# agent holds EXACTLY ONE ho:ObservationSpace (via ho:agentObservation): the
# whole envelope of global state it can observe, a partial projection of
# id:global-state (ho:projectsFrom) bounded above by the agent's
# ho:cognitiveCapacity (150000). A space contains its AreasOfInterest (what
# the role WANTS/NEEDS to observe, ho:hasAreaOfInterest) and its
# AreasOfObservation (what is ACTUALLY observed, ho:hasAreaOfObservation);
# ho:unobserved records what the envelope deliberately excludes. Each space
# rolls up to id:h-multiagent through the ho:hasComponent (hasComponent o
# agentObservation) chain, and its areas through the two-hop extensions, so
# each is a connected, orphan-free component (no direct wiring).
########################################################################

#===================== OBSERVATION SPACES ==============================

id:os-orchestrator a ho:ObservationSpace ;
    skos:prefLabel "Orchestrator observation space" ;
    skos:definition "The observable envelope of the orchestrator node: the dispatch/agent-user/orchestrator-inspection channels, the plan and brief documents, and its own role/cache — a partial projection of the system state bounded by its loss-free capacity." ;
    ho:projectsFrom id:global-state ;
    ho:hasAreaOfInterest id:aoi-orchestrator ;
    ho:hasAreaOfObservation id:oa-orchestrator-external, id:oa-orchestrator-internal ;
    ho:unobserved "The execution internals of the workers it dispatches (spawn is opaque; only returned results enter the envelope)." ;
    ho:maturity "draft" .

id:os-developer a ho:ObservationSpace ;
    skos:prefLabel "Developer observation space" ;
    skos:definition "The observable envelope of the developer node: its own dispatch brief, the assigned ontology nodes as a budget-capped retrieval pack, and its own role/cache — a partial projection of the system state bounded by its loss-free capacity." ;
    ho:projectsFrom id:global-state ;
    ho:hasAreaOfInterest id:aoi-developer ;
    ho:hasAreaOfObservation id:oa-developer-external, id:oa-developer-internal ;
    ho:unobserved "Nodes of the graph outside the brief and the internals of other workers." ;
    ho:maturity "draft" .

id:os-vnv a ho:ObservationSpace ;
    skos:prefLabel "Verification observation space" ;
    skos:definition "The observable envelope of the vnv node: the verification-target artifacts, the validator/tool output over the dispatch channel, and its own role/cache — a partial projection of the system state bounded by its loss-free capacity." ;
    ho:projectsFrom id:global-state ;
    ho:hasAreaOfInterest id:aoi-vnv ;
    ho:hasAreaOfObservation id:oa-vnv-external, id:oa-vnv-internal ;
    ho:unobserved "The authoring internals of the components it judges and the internals of other workers." ;
    ho:maturity "draft" .

id:os-inspection a ho:ObservationSpace ;
    skos:prefLabel "Inspection observation space" ;
    skos:definition "The observable envelope of the inspection node: the WHOLE design graph read wide, the feedback documents over the agent-user/orchestrator-inspection channels, and its own role/cache — a deliberately wide projection paired with a narrow action scope, bounded by its loss-free capacity." ;
    ho:projectsFrom id:global-state ;
    ho:hasAreaOfInterest id:aoi-inspection ;
    ho:hasAreaOfObservation id:oa-inspection-external, id:oa-inspection-internal ;
    ho:unobserved "The internal sessions of the dispatched workers." ;
    ho:maturity "draft" .

id:os-synthesizer a ho:ObservationSpace ;
    skos:prefLabel "Synthesizer observation space" ;
    skos:definition "The observable envelope of the synthesizer node: every worker's deliverable in the shared file workspace and its own role/cache — a partial projection of the system state bounded by its loss-free capacity." ;
    ho:projectsFrom id:global-state ;
    ho:hasAreaOfInterest id:aoi-synthesizer ;
    ho:hasAreaOfObservation id:oa-synthesizer-external, id:oa-synthesizer-internal ;
    ho:unobserved "Each worker's internal reasoning behind the deliverables it converges." ;
    ho:maturity "draft" .

########################################################################
# Areas of interest — the per-agent information requirements (intent).
# Each is a target the role NEEDS/WANTS to observe, independent of whether
# it is realized; the realized AreaOfObservation ho:coversInterest it. No
# ho:tokenEstimate: an interest is intent, not consumed input.
########################################################################

#===================== AREAS OF INTEREST ===============================

id:aoi-orchestrator a ho:AreaOfInterest ;
    skos:prefLabel "Orchestrator area of interest" ;
    skos:definition "What the orchestrator role NEEDS to observe: the workers' returned results and the current plan/brief state, so it can plan the next dispatch." ;
    ho:observationKind "external" ;
    ho:maturity "draft" .

id:aoi-developer a ho:AreaOfInterest ;
    skos:prefLabel "Developer area of interest" ;
    skos:definition "What the developer role NEEDS to observe: its dispatch brief and the specific ontology nodes assigned to it, sufficient to author the assigned individuals correctly." ;
    ho:observationKind "external" ;
    ho:maturity "draft" .

id:aoi-vnv a ho:AreaOfInterest ;
    skos:prefLabel "Verification area of interest" ;
    skos:definition "What the vnv role NEEDS to observe: the composition artifacts under verification and the authoritative validator/tool output, sufficient to render a verdict." ;
    ho:observationKind "external" ;
    ho:maturity "draft" .

id:aoi-inspection a ho:AreaOfInterest ;
    skos:prefLabel "Inspection area of interest" ;
    skos:definition "What the inspection role NEEDS to observe: the whole design graph and the feedback documents, sufficient to trace change ripple and keep a single source of truth." ;
    ho:observationKind "external" ;
    ho:maturity "draft" .

id:aoi-synthesizer a ho:AreaOfInterest ;
    skos:prefLabel "Synthesizer area of interest" ;
    skos:definition "What the synthesizer role NEEDS to observe: every worker's deliverable in the shared workspace, sufficient to cross-check and compile the integrated final result." ;
    ho:observationKind "external" ;
    ho:maturity "draft" .

########################################################################
# Areas of observation — what each agent ACTUALLY observes in one
# inference (realized input data). Each agent holds an EXTERNAL area
# (observing beyond its components: channels via ho:observesChannel, the
# file read-boundary via ho:observedFileScope, the firmware+long-term memory
# tiers) and an INTERNAL area (introspection over its own Role via
# ho:observesComponent and its cache memory). ho:tokenEstimate records the
# realized size each area contributes; the per-agent sum stays far under
# ho:cognitiveCapacity (150000). The external area ho:coversInterest the
# agent's AreaOfInterest (realized meets intended). These areas roll up to
# id:h-multiagent through the two-hop hasComponent chain (hasComponent o
# agentObservation o hasAreaOfObservation), so each is orphan-free.
########################################################################

#===================== AREAS OF OBSERVATION ============================

id:oa-orchestrator-external a ho:AreaOfObservation ;
    skos:prefLabel "Orchestrator external observation" ;
    skos:definition "What the orchestrator perceives beyond itself: the dispatch, agent-user and orchestrator-inspection channels it reads, and the plan/brief documents it plans from." ;
    ho:observationKind "external" ;
    ho:coversInterest id:aoi-orchestrator ;
    ho:observesChannel id:chan-dispatch, id:chan-agent-user, id:chan-orchestrator-inspection ;
    ho:observedFileScope "docs/plans/** and docs/feedback/** (plan and brief documents, read)" ;
    ho:observesMemory id:mem-firmware, id:mem-longterm ;
    ho:unobserved "The execution internals of the workers it dispatches (spawn is opaque; only returned results are perceived)." ;
    ho:tokenEstimate 9000 ; ho:maturity "draft" .

id:oa-orchestrator-internal a ho:AreaOfObservation ;
    skos:prefLabel "Orchestrator internal observation" ;
    skos:definition "The orchestrator's introspection over its own constituent parts: its role (mandate/policy) and its task-scoped cache memory holding the plan state." ;
    ho:observationKind "internal" ;
    ho:observesComponent id:role-orchestrator ;
    ho:observesMemory id:mem-cache ;
    ho:unobserved "Any component of another agent (only its own parts are introspected)." ;
    ho:tokenEstimate 2000 ; ho:maturity "draft" .

id:oa-developer-external a ho:AreaOfObservation ;
    skos:prefLabel "Developer external observation" ;
    skos:definition "What the developer perceives beyond itself: its own dispatch brief over the dispatch channel and the assigned ontology nodes retrieved as a budget-capped pack (never the whole store)." ;
    ho:observationKind "external" ;
    ho:coversInterest id:aoi-developer ;
    ho:observesChannel id:chan-dispatch ;
    ho:observedFileScope "The assigned brief and only the assigned ontology/abox nodes, as a budget-capped retrieval pack" ;
    ho:observesMemory id:mem-firmware, id:mem-longterm ;
    ho:unobserved "Nodes of the graph outside the brief and the internals of other workers." ;
    ho:tokenEstimate 6000 ; ho:maturity "draft" .

id:oa-developer-internal a ho:AreaOfObservation ;
    skos:prefLabel "Developer internal observation" ;
    skos:definition "The developer's introspection over its own constituent parts: its role and its task-scoped cache memory." ;
    ho:observationKind "internal" ;
    ho:observesComponent id:role-developer ;
    ho:observesMemory id:mem-cache ;
    ho:unobserved "Any component of another agent." ;
    ho:tokenEstimate 1500 ; ho:maturity "draft" .

id:oa-vnv-external a ho:AreaOfObservation ;
    skos:prefLabel "Verification external observation" ;
    skos:definition "What the vnv agent perceives beyond itself: the verification-target artifacts handed to it over the dispatch channel and the validator/tool output it evaluates." ;
    ho:observationKind "external" ;
    ho:coversInterest id:aoi-vnv ;
    ho:observesChannel id:chan-dispatch ;
    ho:observedFileScope "The composition artifacts under verification and the validate.py/tool output, read" ;
    ho:observesMemory id:mem-firmware, id:mem-longterm ;
    ho:unobserved "The authoring internals of the components it judges and the internals of other workers." ;
    ho:tokenEstimate 5000 ; ho:maturity "draft" .

id:oa-vnv-internal a ho:AreaOfObservation ;
    skos:prefLabel "Verification internal observation" ;
    skos:definition "The vnv agent's introspection over its own constituent parts: its role and its task-scoped cache memory." ;
    ho:observationKind "internal" ;
    ho:observesComponent id:role-vnv ;
    ho:observesMemory id:mem-cache ;
    ho:unobserved "Any component of another agent." ;
    ho:tokenEstimate 1500 ; ho:maturity "draft" .

id:oa-inspection-external a ho:AreaOfObservation ;
    skos:prefLabel "Inspection external observation" ;
    skos:definition "What the inspection agent perceives beyond itself: the WHOLE design graph read wide, plus the feedback documents over the agent-user and orchestrator-inspection channels. A deliberately wide perception paired with a narrow action scope." ;
    ho:observationKind "external" ;
    ho:coversInterest id:aoi-inspection ;
    ho:observesChannel id:chan-agent-user, id:chan-orchestrator-inspection ;
    ho:observedFileScope "The whole design graph (ontology/** and docs/**) read, plus docs/feedback/** " ;
    ho:observesMemory id:mem-firmware, id:mem-longterm ;
    ho:unobserved "The internal sessions of the dispatched workers." ;
    ho:tokenEstimate 12000 ; ho:maturity "draft" .

id:oa-inspection-internal a ho:AreaOfObservation ;
    skos:prefLabel "Inspection internal observation" ;
    skos:definition "The inspection agent's introspection over its own constituent parts: its role and its session cache memory." ;
    ho:observationKind "internal" ;
    ho:observesComponent id:role-inspection ;
    ho:observesMemory id:mem-cache ;
    ho:unobserved "Any component of another agent." ;
    ho:tokenEstimate 1500 ; ho:maturity "draft" .

id:oa-synthesizer-external a ho:AreaOfObservation ;
    skos:prefLabel "Synthesizer external observation" ;
    skos:definition "What the synthesizer perceives beyond itself: every worker's deliverable in the shared file workspace, picked up from one place for cross-check and integration." ;
    ho:observationKind "external" ;
    ho:coversInterest id:aoi-synthesizer ;
    ho:observesChannel id:chan-workspace ;
    ho:observedFileScope "All worker deliverable artifacts in the shared workspace directory, read" ;
    ho:observesMemory id:mem-firmware, id:mem-longterm ;
    ho:unobserved "Each worker's internal reasoning behind the deliverables it converges." ;
    ho:tokenEstimate 8000 ; ho:maturity "draft" .

id:oa-synthesizer-internal a ho:AreaOfObservation ;
    skos:prefLabel "Synthesizer internal observation" ;
    skos:definition "The synthesizer's introspection over its own constituent parts: its role and its task-scoped cache memory." ;
    ho:observationKind "internal" ;
    ho:observesComponent id:role-synthesizer ;
    ho:observesMemory id:mem-cache ;
    ho:unobserved "Any component of another agent." ;
    ho:tokenEstimate 1500 ; ho:maturity "draft" .
