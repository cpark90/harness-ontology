@prefix ho:    <https://harness-ontology.dev/schema#> .
@prefix id:    <https://harness-ontology.dev/id/core/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .

# Core data unit -- Domain + Task partition of the `core` domain. Imports the
# central TBox only; cross-unit references resolve in the root union
# (docs/federation-design.md D1, ONTOLOGYSTYLE 4).
<https://harness-ontology.dev/data/core/domains-tasks> a owl:Ontology ;
    owl:imports <https://harness-ontology.dev/schema> .

#===================== Domains =========================================
id:dom-coding a ho:Domain ; skos:prefLabel "Software coding" ; skos:altLabel "programming" ; ho:salience 0.9 .
id:dom-research a ho:Domain ; skos:prefLabel "Research" ; skos:altLabel "literature research" ; ho:salience 0.8 .
id:dom-support a ho:Domain ; skos:prefLabel "Customer support" ; skos:altLabel "helpdesk" ; ho:salience 0.7 .
id:dom-design a ho:Domain ; skos:prefLabel "Design engineering" ; skos:altLabel "structured design work" ; ho:scopedFrom id:env-space ; ho:salience 0.6 .

#===================== Information-space projection chain ===============
# The upper two tiers of the observation projection chain
# (EnvironmentSpace -> Domain -> GlobalState -> ObservationSpace, plan
# mas-observation-refinement.md §3e). Both are non-component concepts
# (like ho:Domain): no ho:hasComponent wiring, not covered by
# ho:ComponentConnectivityShape. The chain is closed above by
# id:dom-design ho:scopedFrom id:env-space (problem-definition cut) and
# below by each ObservationSpace ho:projectsFrom id:global-state
# (partial, capacity-bounded projection).

id:env-space a ho:EnvironmentSpace ;
    skos:prefLabel "Environment space" ;
    skos:definition "The environment space: all reality and system space plus its unbounded information — the infinite source outside the system from which a Domain is carved by problem definition. The top of the observation projection chain; a Domain narrows it via ho:scopedFrom." ;
    ho:maturity "draft" .

id:global-state a ho:GlobalState ;
    skos:prefLabel "Global state space" ;
    skos:definition "The global state describing the system within its Domain (the S of a decentralized POMDP). It is the source each agent's ObservationSpace partially projects from (ho:projectsFrom), bounded by the agent's cognitive limit — this is why a local observation is only a slice of the whole state." ;
    ho:describesDomain id:dom-design ;
    ho:maturity "draft" .

#===================== Tasks ===========================================
id:task-bugfix a ho:Task ; skos:prefLabel "Bug fixing" ; skos:altLabel "debugging" ;
    skos:definition "Locate and repair a defect in a codebase." .
id:task-codereview a ho:Task ; skos:prefLabel "Code review" ;
    skos:definition "Assess a code change for correctness and quality." .
id:task-litreview a ho:Task ; skos:prefLabel "Literature review" ;
    skos:definition "Survey and synthesise sources on a topic with citations." .
id:task-triage a ho:Task ; skos:prefLabel "Ticket triage" ;
    skos:definition "Classify and route an incoming support ticket." .
id:task-architecture a ho:Task ; skos:prefLabel "Architecture design" ;
    skos:definition "Define the end-to-end structure, components and interfaces of a system from goals and quantitative targets." .
id:task-designdecision a ho:Task ; skos:prefLabel "Design issue resolution" ; skos:altLabel "decision lifecycle" ;
    skos:definition "Drive an open design question to a confirmed, grounded decision while preserving traceability from issue to requirement." .
