@prefix ho:    <https://harness-ontology.dev/schema#> .
@prefix id:    <https://harness-ontology.dev/id/core/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .

# Core data unit -- Guardrail partition of the `core` domain. Imports the
# central TBox only; cross-unit references resolve in the root union
# (docs/federation-design.md D1, ONTOLOGYSTYLE 4).
<https://harness-ontology.dev/data/core/guardrails> a owl:Ontology ;
    owl:imports <https://harness-ontology.dev/schema> .

#===================== Guardrails ======================================
id:gr-nodestruct a ho:Guardrail ; skos:prefLabel "No destructive actions" ;
    ho:promptText "Never run irreversible or destructive commands without explicit confirmation." ;
    ho:tokenEstimate 30 ; ho:maturity "stable" ; ho:tagged id:c-safety .
id:gr-cite a ho:Guardrail ; skos:prefLabel "Cite sources" ; skos:altLabel "no fabrication" ;
    ho:promptText "Every factual claim must carry a citation to a retrieved source." ;
    ho:providesCapability id:cap-citation ; ho:tokenEstimate 25 ; ho:maturity "stable" ; ho:tagged id:c-safety .
id:gr-lang a ho:Guardrail ; skos:prefLabel "Korean/English only" ; skos:altLabel "language policy" ;
    ho:languageCondition "Prose (documentation, comments, harness .md): Korean" ,
        "Technical terms, including in answers: English" ,
        "Code, identifiers, commit messages: English" ;
    ho:promptText "Use only Korean and English, unless another language is essential to the task: write prose (documentation, comments, harness .md) in Korean but keep technical terms in English; write code, identifiers and commit messages in English." ;
    ho:tokenEstimate 44 ; ho:maturity "draft" ; ho:tagged id:c-communication .
id:gr-verify-proceed a ho:Guardrail ; skos:prefLabel "Verify then proceed" ; skos:altLabel "no time assumptions" ;
    ho:promptText "Never assume readiness from elapsed time; advance only on confirmed state (received response, ACK, verified flag). Timeouts are give-up bounds, not correctness premises." ;
    ho:tagged id:c-verify-proceed ; ho:tokenEstimate 38 ; ho:maturity "reviewed" .
id:gr-design-for-loss a ho:Guardrail ; skos:prefLabel "Design for loss" ;
    ho:promptText "Treat message and data loss as a normal event, not an exception: judge completion by the final receiver's confirmation, hold custody until the next stage confirms receipt, report cumulative absolute state rather than deltas, and make every loss observable via counters." ;
    ho:tagged id:c-design-for-loss ; ho:tokenEstimate 55 ; ho:maturity "reviewed" .
id:gr-traceability a ho:Guardrail ; skos:prefLabel "Traceable single source of truth" ;
    ho:promptText "Single source of truth with full traceability: never delete a decision or record -- mark it deprecated with a reason and a replacement link, and only ever increment identifiers, never reuse them." ;
    ho:providesCapability id:cap-traceability ;
    ho:tagged id:c-traceability ; ho:tokenEstimate 42 ; ho:maturity "reviewed" .
id:gr-grounding a ho:Guardrail ; skos:prefLabel "Ground every artifact" ;
    skos:altLabel "assumption and limitation disclosure" , "flag unverified claims" ;
    ho:promptText "Link every derived artifact to its grounding decision or rationale; do not restate another document, reference its single source. Describe an interface identically on both sides and let the requirement win on conflict." ;
    ho:tagged id:c-grounding ; ho:tokenEstimate 42 ; ho:maturity "reviewed" .
id:gr-structural-coverage a ho:Guardrail ; skos:prefLabel "Structural coverage completeness" ; skos:altLabel "source-fidelity reflection" ;
    ho:promptText "When reflecting a system into the model, exhaustively enumerate the source's structural elements and map each to a representation; an element with no existing vocabulary is a signal to EXTEND the schema, never to silently skip it; verify coverage against the source before declaring the reflection done." ;
    ho:tagged id:c-structural-coverage ; ho:tokenEstimate 58 ; ho:maturity "reviewed" .
id:gr-no-arbitrary-decision a ho:Guardrail ; skos:prefLabel "No arbitrary decisions" ;
    ho:promptText "Do not resolve an undecided question on your own; register each open judgment as an issue and escalate it to the decision authority." ;
    ho:tagged id:c-escalation ; ho:tokenEstimate 32 ; ho:maturity "reviewed" .
id:gr-least-privilege a ho:Guardrail ; skos:prefLabel "Least-privilege role boundaries" ;
    ho:promptText "Each role edits only the files inside its own responsibility boundary and holds the minimum permissions for its task; authoring, judgment, application and version control stay in separate hands." ;
    ho:tagged id:c-least-privilege ; ho:tokenEstimate 40 ; ho:maturity "reviewed" .
id:gr-report-over-prompt a ho:Guardrail ; skos:prefLabel "Report over prompt" ;
    ho:promptText "Write status, decisions, questions and reports to durable channels rather than volatile chat, and leave only a one-line pointer to where each was written." ;
    ho:tagged id:c-report-over-prompt ; ho:tokenEstimate 36 ; ho:maturity "reviewed" .
id:gr-controlled-vocabulary a ho:Guardrail ; skos:prefLabel "Controlled vocabulary" ; skos:altLabel "anti-drift" ;
    ho:promptText "Reuse the registered vocabulary and established domain terms; do not coin near-synonyms or private abbreviations. New terms are added to the single terminology source, not improvised." ;
    ho:tagged id:c-controlled-vocabulary ; ho:tokenEstimate 40 ; ho:maturity "reviewed" .
id:gr-root-cause a ho:Guardrail ; skos:prefLabel "Fix root cause" ;
    ho:promptText "Resolve problems at their root cause; do not mask a symptom with a guard that leaves the underlying fault in place." ;
    ho:tagged id:c-root-cause ; ho:tokenEstimate 28 ; ho:maturity "reviewed" .
id:gr-simplicity a ho:Guardrail ; skos:prefLabel "Prefer the simplest working form" ; skos:altLabel "YAGNI" ;
    ho:promptText "Prefer the simplest form that works; remove branches rather than add them, and do not build speculative configuration, callbacks or generalization that nothing uses yet." ;
    ho:tagged id:c-simplicity ; ho:tokenEstimate 38 ; ho:maturity "reviewed" .
id:gr-bounded-context a ho:Guardrail ; skos:prefLabel "Bounded context projection" ; skos:altLabel "anti-context-rot" ;
    ho:promptText "Never ingest the whole knowledge store into context; retrieve only a request-scoped, budget-capped projection and keep the working context bounded to defend against context rot." ;
    ho:tagged id:c-bounded-context ; ho:tokenEstimate 40 ; ho:maturity "reviewed" .
id:gr-dispatch-execution a ho:Guardrail ; skos:prefLabel "Dispatch-based execution" ; skos:altLabel "no standalone workers" ;
    ho:promptText "Worker agents perform their assigned work only when dispatched by the orchestrator; they are not run standalone or invoked directly outside a dispatch." ;
    ho:tagged id:c-dispatch ; ho:tokenEstimate 34 ; ho:maturity "reviewed" .
id:gr-delegated-orchestration a ho:Guardrail ; skos:prefLabel "Delegated-only orchestration" ; skos:altLabel "orchestrator does not work directly" ;
    ho:promptText "The user-facing orchestrator performs no substantive work directly -- no authoring, judgment or tool execution; it only plans and dispatches, and all such work is carried out through the worker agents." ;
    ho:tagged id:c-delegation ; ho:tokenEstimate 42 ; ho:maturity "reviewed" .
id:gr-reuse-first a ho:Guardrail ; skos:prefLabel "Reuse-first composition" ; skos:altLabel "anti-orphan authoring" ;
    ho:promptText "Compose by REUSING existing typed parts first; author a new part only when none fits, and in the same change connect it (a broader parent / a tag / a provider) so it is never an orphan -- this is the anti-drift, anti-orphan discipline of composition." ;
    ho:tagged id:c-reuse-first ; ho:tokenEstimate 62 ; ho:maturity "reviewed" .
id:gr-structured-output a ho:Guardrail ; skos:prefLabel "Structured output" ; skos:altLabel "deliverable template" ;
    ho:promptText "Emit every deliverable in the agreed structured template for its type -- consistent sections, headings and fields -- so downstream roles and any convergence gate can consume it mechanically rather than re-parsing free-form prose." ;
    ho:tagged id:c-structured-output ; ho:tokenEstimate 40 ; ho:maturity "reviewed" .
id:gr-scale-modes a ho:Guardrail ; skos:prefLabel "Scale execution modes" ;
    skos:altLabel "full/reduced/single modes" , "full pipeline mode" , "review mode" ;
    ho:promptText "Match effort to the request's scope: run the full agent team for a broad request, a reduced subset of roles for a narrow one, and a single pass for a trivial one -- scale the active roles and workflow to the scope rather than always running everything." ;
    ho:tagged id:c-scale-modes ; ho:tokenEstimate 46 ; ho:maturity "reviewed" .
id:gr-graceful-fallback a ho:Guardrail ; skos:prefLabel "Graceful fallback" ; skos:altLabel "error fallback" ;
    ho:promptText "Anticipate failure per operation and degrade gracefully: for each foreseeable failure mode define a fallback (retry, reduced-scope result, or a clearly flagged partial deliverable) rather than aborting the whole run, and make any degradation explicit in the output." ;
    ho:tagged id:c-graceful-fallback ; ho:tokenEstimate 48 ; ho:maturity "reviewed" .

#===================== Complexity governance (orchestration limits) ====
id:gr-depth-limit a ho:Guardrail ; skos:prefLabel "Delegation depth limit" ; skos:altLabel "at most two levels" ;
    ho:promptText "Limit delegation to at most two levels deep: a coordinator may delegate to workers, but those workers do not spawn further sub-teams, keeping the call graph shallow and debuggable." ;
    ho:tagged id:c-complexity-governance ; ho:tokenEstimate 42 ; ho:maturity "draft" .
id:gr-no-nested-teams a ho:Guardrail ; skos:prefLabel "No nested teams" ;
    ho:promptText "Do not nest agent teams inside agent teams: a team's workers are leaf agents, not themselves leaders of further teams." ;
    ho:tagged id:c-complexity-governance ; ho:tokenEstimate 30 ; ho:maturity "draft" .
id:gr-single-active-team a ho:Guardrail ; skos:prefLabel "Single active team" ;
    ho:promptText "Keep exactly one agent team active at a time rather than running multiple concurrent teams, so coordination state stays observable and contention is avoided." ;
    ho:tagged id:c-complexity-governance ; ho:tokenEstimate 38 ; ho:maturity "draft" .
id:gr-bottleneck-avoidance a ho:Guardrail ; skos:prefLabel "Avoid coordination bottlenecks" ; skos:altLabel "parallel-first scheduling" ;
    ho:promptText "Do not funnel every hand-off through a single coordinator when the work is parallelisable; distribute coordination so that one agent does not become a throughput bottleneck." ;
    ho:tagged id:c-complexity-governance ; ho:tokenEstimate 40 ; ho:maturity "draft" .
id:gr-flatten-hierarchy a ho:Guardrail ; skos:prefLabel "Flatten the hierarchy" ;
    ho:promptText "Prefer the flattest agent hierarchy that solves the task; add a coordination layer only when depth is genuinely required, not by default." ;
    ho:tagged id:c-complexity-governance ; ho:tokenEstimate 34 ; ho:maturity "draft" .
id:gr-bounded-iteration a ho:Guardrail ; skos:prefLabel "Bounded iteration" ; skos:altLabel "retry cap" ;
    ho:promptText "Cap corrective iteration: a producer-reviewer or retry loop runs at most two to three rounds, then escalates or returns a clearly flagged partial rather than looping unbounded." ;
    ho:tagged id:c-complexity-governance ; ho:tokenEstimate 40 ; ho:maturity "draft" .

#===================== Verification, authoring and model governance ====
id:gr-integration-coherence a ho:Guardrail ; skos:prefLabel "Integration coherence" ; skos:altLabel "boundary cross-check" ;
    ho:promptText "Read the producer and the consumer of an interface together and cross-check that the two sides agree at their shared boundary; prefer connection checks over mere existence checks. Distinct from grounding (id:gr-grounding), which links an artifact to its rationale -- this verifies that two components actually fit where they meet." ;
    ho:tagged id:c-grounding ; ho:tokenEstimate 72 ; ho:maturity "draft" .
id:gr-discriminating-eval a ho:Guardrail ; skos:prefLabel "Discriminating evaluation" ; skos:altLabel "baseline differential" ;
    ho:promptText "Evaluate against a baseline so the test discriminates: compare behaviour with and without the component under test, and discard any assertion that passes in both arms because it proves nothing about the component." ;
    ho:tagged id:c-agent-methodology ; ho:tokenEstimate 48 ; ho:maturity "draft" .
id:gr-single-responsibility a ho:Guardrail ; skos:prefLabel "Single responsibility per role" ;
    ho:promptText "Give each role exactly one clear responsibility; if a role accretes a second distinct duty, split it into two roles rather than overloading one." ;
    ho:tagged id:c-least-privilege ; ho:tokenEstimate 34 ; ho:maturity "draft" .
id:gr-generalize-not-overfit a ho:Guardrail ; skos:prefLabel "Generalize, do not overfit" ;
    ho:promptText "When acting on feedback, fix the underlying principle rather than the single reported instance: generalize the correction into a reusable rule instead of patching one case and leaving the class of problem open." ;
    ho:tagged id:c-design ; ho:tokenEstimate 50 ; ho:maturity "draft" .
id:gr-absolute-paths a ho:Guardrail ; skos:prefLabel "Absolute workspace paths" ;
    ho:promptText "Reference shared-workspace files by absolute path rooted at the workspace directory rather than by relative path, so every agent and session resolves the same file regardless of its working directory." ;
    ho:tagged id:c-multiagent ; ho:tokenEstimate 46 ; ho:maturity "draft" .
id:gr-well-formed-skill a ho:Guardrail ; skos:prefLabel "Well-formed skill" ;
    ho:promptText "Author every skill in well-formed shape: a present description, the required section headings and no forbidden files, so the skill is discoverable, invocable and passes its structural contract." ;
    ho:tagged id:c-skill-authoring ; ho:tokenEstimate 46 ; ho:maturity "draft" .
id:gr-opus-required a ho:Guardrail ; skos:prefLabel "Opus model required" ; skos:altLabel "dispatch model floor" ;
    ho:promptText "Spawn quality-critical dispatch roles (authoring and judgment) on the top-tier model, since their output determines final correctness; make the model requirement explicit rather than leaving it to template default." ;
    ho:tagged id:c-multiagent ; ho:tokenEstimate 50 ; ho:maturity "draft" .

#===================== Team review, routing and acceptance discipline ==
id:gr-cross-validation a ho:Guardrail ; skos:prefLabel "Cross-validate every deliverable" ; skos:altLabel "severity-triaged peer review" ;
    ho:promptText "Have every deliverable cross-validated by a role other than the one that produced it, and grade each finding by severity; force rework only for the top severity band and carry the lower bands as recorded, accepted observations, so review converges instead of reopening the work on every remark." ;
    ho:tagged id:c-cross-validation ; ho:tokenEstimate 62 ; ho:maturity "draft" .
id:gr-declared-routes a ho:Guardrail ; skos:prefLabel "Declared hand-off routes" ; skos:altLabel "explicit communication protocol" ;
    ho:promptText "Each role declares its own outbound hand-off routes -- which role it sends what to, and on what event -- as part of its own definition, so the coordination topology is readable from the parts themselves instead of being inferred from a diagram kept somewhere else." ;
    ho:tagged id:c-communication ; ho:tokenEstimate 60 ; ho:maturity "draft" .
id:gr-sequenced-artifacts a ho:Guardrail ; skos:prefLabel "Sequenced workspace artifacts" ; skos:altLabel "ordinal artifact naming" ;
    ho:promptText "Name every shared-workspace artifact with an ordinal prefix followed by its document type and extension, so production order is visible from a plain directory listing and each consumer resolves the exact file its producer wrote rather than guessing among similar names." ;
    ho:tagged id:c-deliverable-artifact ; ho:tokenEstimate 54 ; ho:maturity "draft" .
id:gr-three-flow-acceptance a ho:Guardrail ; skos:prefLabel "Three-flow acceptance coverage" ; skos:altLabel "normal, resumed and error fixtures" ;
    ho:promptText "Cover all three run flows with behaviour fixtures before calling a harness accepted: the normal path from empty state, the path resumed over existing input, and the error path; a fixture set that exercises only the happy path is a demonstration, not an acceptance." ;
    ho:tagged id:c-acceptance-coverage ; ho:tokenEstimate 58 ; ho:maturity "draft" .
