@prefix ho:    <https://harness-ontology.dev/schema#> .
@prefix id:    <https://harness-ontology.dev/id/core/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .

# Core data unit -- Role partition of the `core` domain. Imports the
# central TBox only; cross-unit references (the h-multiagent harness binding
# these roles via hasRole, the tools/guardrails each role scopes via
# roleTool/roleGuardrail, the c-multiagent/c-design tags) resolve in the
# root union (docs/federation-design.md D1, ONTOLOGYSTYLE 4).
<https://harness-ontology.dev/data/core/roles> a owl:Ontology ;
    owl:imports <https://harness-ontology.dev/schema> .

########################################################################
# Sub-agent roles — the neutral multi-agent role taxonomy.
#
# Each role is characterised, not just classified: its defining traits are
# modelled explicitly so a harness can make its agent perform the role
# clearly — the governance it operates under (ho:roleGuardrail), the
# least-privilege tools in its scope (ho:roleTool), and its memory
# discipline (ho:roleMemoryPolicy). ho:userFacing is OPTIONAL: it is present
# (true) only on roles that communicate with the user; its ABSENCE means the
# role is dispatch-invoked and does not talk to the user (it is not a
# defining/required property). All roles are bound to the neutral
# id:h-multiagent template via ho:hasRole (subPropertyOf hasComponent) and
# scope only parts that harness already binds (usesTool / hasGuardrail), so
# each stays a connected, orphan-free HarnessComponent.
########################################################################

#===================== ROLES ===========================================

id:role-orchestrator a ho:Role ;
    skos:prefLabel "Orchestrator agent" ;
    skos:definition "The user-facing planner that decomposes a request into node-scoped briefs and dispatches them to workers, then integrates and gate-checks their results. Performs no substantive work itself." ;
    ho:roleGuardrail id:gr-delegated-orchestration, id:gr-report-over-prompt,
        id:gr-bounded-context, id:gr-reuse-first ;
    ho:tagged id:c-multiagent ;
    ho:roleMemoryPolicy "Reads and writes only its own role-scoped memory at session start/end; plans from a bounded retrieval pack, never the whole store." ;
    ho:userFacing true ; ho:maturity "reviewed" .

id:role-inspection a ho:Role ;
    skos:prefLabel "Inspection agent" ;
    skos:definition "The user-facing role that handles user feedback and its ripple effects and owns the git lifecycle in its own session." ;
    ho:roleTool id:tool-shell, id:tool-editor ;
    ho:roleGuardrail id:gr-traceability, id:gr-report-over-prompt,
        id:gr-least-privilege, id:gr-verify-proceed ;
    ho:tagged id:c-multiagent ;
    ho:roleMemoryPolicy "Runs in its own session; reads and writes only its own role-scoped memory at session start/end and consumes the feedback channel by verified status, never by elapsed time." ;
    ho:userFacing true ; ho:maturity "reviewed" .

id:role-developer a ho:Role ;
    skos:prefLabel "Developer agent" ;
    skos:definition "A work-performing role, dispatch-invoked only, that authors the ontology nodes (abox individuals) assigned in a brief, reusing the controlled vocabulary." ;
    ho:roleTool id:tool-editor, id:tool-shell ;
    ho:roleGuardrail id:gr-dispatch-execution, id:gr-least-privilege,
        id:gr-reuse-first, id:gr-controlled-vocabulary ;
    ho:tagged id:c-multiagent ;
    ho:roleMemoryPolicy "Reads its own role-scoped memory at session start and writes back reusable authoring knowledge at session end; touches no other role's memory." ;
    ho:maturity "reviewed" .

id:role-research a ho:Role ;
    skos:prefLabel "Research agent" ;
    skos:definition "A work-performing role, dispatch-invoked only, that gathers and synthesises information needed by a brief, grounding each finding in its source." ;
    ho:roleTool id:tool-websearch, id:tool-retriever ;
    ho:roleGuardrail id:gr-dispatch-execution, id:gr-least-privilege,
        id:gr-grounding, id:gr-bounded-context ;
    ho:tagged id:c-multiagent ;
    ho:roleMemoryPolicy "Reads its own role-scoped memory at session start and writes back reusable findings at session end; touches no other role's memory." ;
    ho:maturity "reviewed" .

id:role-inspection-worker a ho:Role ;
    skos:prefLabel "Inspection worker agent" ;
    skos:definition "A work-performing role, dispatch-invoked only, that carries out inspection/investigation tasks and reports findings; distinct from the user-facing inspection role." ;
    ho:roleTool id:tool-retriever, id:tool-shell ;
    ho:roleGuardrail id:gr-dispatch-execution, id:gr-least-privilege,
        id:gr-report-over-prompt, id:gr-verify-proceed ;
    ho:tagged id:c-multiagent ;
    ho:roleMemoryPolicy "Reads its own role-scoped memory at session start and writes back reusable investigation notes at session end; touches no other role's memory." ;
    ho:maturity "reviewed" .

id:role-vnv a ho:Role ;
    skos:prefLabel "Verification and validation agent" ;
    skos:definition "A work-performing role, dispatch-invoked only, that verifies and evaluates composition results and returns a verdict on confirmed state, escalating rather than deciding open questions." ;
    ho:roleTool id:tool-shell, id:tool-retriever ;
    ho:roleGuardrail id:gr-dispatch-execution, id:gr-least-privilege,
        id:gr-verify-proceed, id:gr-no-arbitrary-decision ;
    ho:tagged id:c-multiagent ;
    ho:roleMemoryPolicy "Reads its own role-scoped memory at session start and writes back reusable verification heuristics at session end; touches no other role's memory." ;
    ho:maturity "reviewed" .

id:role-design a ho:Role ;
    skos:prefLabel "Design agent" ;
    skos:definition "A work-performing role, dispatch-invoked only, dedicated to design work (system/architecture design tasks): choosing the simplest working form, fixing root causes, and grounding each decision." ;
    ho:roleGuardrail id:gr-dispatch-execution, id:gr-least-privilege,
        id:gr-simplicity, id:gr-root-cause, id:gr-grounding ;
    ho:tagged id:c-multiagent, id:c-design ;
    ho:roleMemoryPolicy "Reads its own role-scoped memory at session start and writes back reusable design rationale at session end; touches no other role's memory." ;
    ho:maturity "reviewed" .

# The final convergence gate of a multi-agent harness: a work-performing role
# that both cross-checks every worker's deliverable AND compiles the reviewed
# contributions into one coherent final result. Broader than id:role-vnv (which
# only judges and returns a verdict) -- a neutral sibling that also PRODUCES the
# integrated output, so it provides id:cap-synthesis. Recurs across the corpus of
# multi-agent harnesses as the reviewer/writer/synthesizer terminal step.
id:role-synthesizer a ho:Role ;
    skos:prefLabel "Synthesizer agent" ; skos:altLabel "convergence/reviewer gate" ;
    skos:definition "A work-performing role, dispatch-invoked only, that serves as the terminal convergence gate of a multi-agent harness: it cross-checks every worker's deliverable, requests bounded rework on the issues it finds, and compiles the reviewed contributions into one coherent final result. Broader than the verification role, which only judges and returns a verdict -- the synthesizer also produces the integrated deliverable, so it provides the synthesis capability." ;
    ho:roleTool id:tool-editor ;
    ho:roleGuardrail id:gr-dispatch-execution, id:gr-least-privilege,
        id:gr-structured-output, id:gr-grounding ;
    ho:providesCapability id:cap-synthesis ;
    ho:tagged id:c-multiagent, id:c-synthesis ;
    ho:roleMemoryPolicy "Reads its own role-scoped memory at session start and writes back reusable synthesis/review heuristics at session end; touches no other role's memory." ;
    ho:maturity "reviewed" .

########################################################################
# Agent memory tiers — the neutral memory architecture an agent maintains,
# co-located with the roles (agent-state) because ho:roleMemoryPolicy above is
# a single free-text directive that cannot express the THREE distinct tiers an
# agent keeps. Each tier is a first-class ho:Memory component distinguished by
# WHEN it is read (ho:memoryReadTiming) and HOW LONG it persists
# (ho:memoryPersistence): firmware (always read in full, durable baseline),
# cache (accumulated within one spawned task, ephemeral) and long-term (read
# only on a trigger, durable, consulted selectively). All three are bound to
# the neutral id:h-multiagent template via ho:hasMemory (subPropertyOf
# hasComponent) so each is a connected, orphan-free HarnessComponent.
########################################################################

#===================== MEMORY TIERS ====================================

id:mem-firmware a ho:Memory ;
    skos:prefLabel "Firmware memory" ;
    skos:definition "The fixed baseline memory an agent MUST read in full on every execution/spawn: its always-loaded, mandatory ruleset, read whole each time so it frames behaviour before any task-specific state." ;
    ho:memoryReadTiming "every-execution" ;
    ho:memoryPersistence "durable" ;
    ho:memoryReadScope "full" ;
    ho:tagged id:c-memory, id:c-multiagent ;
    ho:tokenEstimate 55 ; ho:maturity "draft" .

id:mem-cache a ho:Memory ;
    skos:prefLabel "Cache memory" ;
    skos:definition "The task-scoped working memory that accumulates the agent's behaviour rules within a single spawned task and is discarded when that task ends: volatile, internal to the spawn, never surviving it." ;
    ho:memoryReadTiming "task-continuous" ;
    ho:memoryPersistence "ephemeral" ;
    ho:memoryReadScope "full" ;
    ho:tagged id:c-memory, id:c-multiagent ;
    ho:tokenEstimate 55 ; ho:maturity "draft" .

id:mem-longterm a ho:Memory ;
    skos:prefLabel "Long-term memory" ;
    skos:definition "Durable memory NOT read on every execution/spawn; the agent consults and reflects only the relevant portion when a defined condition is met, pulling it in selectively on demand rather than loading it each time." ;
    ho:memoryReadTiming "conditional" ;
    ho:memoryPersistence "durable" ;
    ho:memoryReadScope "selective" ;
    ho:memoryActivationCondition "A defined trigger condition is met (e.g. the current task matches the memory's applicability); only then is the relevant portion consulted and reflected." ;
    ho:tagged id:c-memory, id:c-multiagent ;
    ho:tokenEstimate 80 ; ho:maturity "draft" .

########################################################################
# Operating agents — this repo's own five agents modelled as MAS nodes.
#
# Each ho:Agent is the partially-observed distributed node the harness
# compiles from a Role: it bundles ho:agentRole (its mandate/policy, an
# existing role above), ho:agentObservation (exactly one ObservationSpace =
# its observable envelope Omega_i, declared in the next section), and
# ho:agentFunction (its action space A_i, EXISTING capabilities the harness
# already provides/requires). All five share one modelled ho:cognitiveCapacity
# (150000) — the loss-free context each can use in one inference, derived
# from and kept consistent with id:mc-opus; the summed ho:tokenEstimate of
# an agent's AreasOfObservation stays well within it (capacity fit, checked by
# review since SHACL cannot sum). Bound to id:h-multiagent via ho:hasAgent
# (a sub-property of hasComponent, so each agent is a connected, orphan-free
# component and its ObservationSpace + areas roll up by the hasComponent chain).
########################################################################

#===================== AGENTS ==========================================

id:agent-orchestrator a ho:Agent ;
    skos:prefLabel "Orchestrator agent (node)" ;
    skos:definition "The planning/dispatch node the harness compiles from the orchestrator role: it perceives the dispatch, agent-user and orchestrator-inspection channels and the plan/brief documents (external area) plus its own role and cache (internal area), and its function is multi-agent orchestration. It does NOT observe any worker's execution internals." ;
    ho:agentRole id:role-orchestrator ;
    ho:agentObservation id:os-orchestrator ;
    ho:agentFunction id:cap-orchestration ;
    ho:cognitiveCapacity 150000 ;
    ho:tagged id:c-multiagent ;
    ho:maturity "draft" .

id:agent-developer a ho:Agent ;
    skos:prefLabel "Developer agent (node)" ;
    skos:definition "The authoring node the harness compiles from the developer role: it perceives its own dispatch brief and the assigned ontology nodes as a budget-capped retrieval pack (external area) plus its own role and cache (internal area), and its functions are file editing and code execution. It does NOT observe other nodes of the graph or other workers' internals." ;
    ho:agentRole id:role-developer ;
    ho:agentObservation id:os-developer ;
    ho:agentFunction id:cap-fileedit, id:cap-codeexec ;
    ho:cognitiveCapacity 150000 ;
    ho:tagged id:c-multiagent ;
    ho:maturity "draft" .

id:agent-vnv a ho:Agent ;
    skos:prefLabel "Verification agent (node)" ;
    skos:definition "The verification node the harness compiles from the vnv role: it perceives the verification-target artifacts and the validator/tool output over the dispatch channel (external area) plus its own role and cache (internal area), and its function is code execution (running the validators). It does NOT observe the authoring internals of the components it judges." ;
    ho:agentRole id:role-vnv ;
    ho:agentObservation id:os-vnv ;
    ho:agentFunction id:cap-codeexec ;
    ho:cognitiveCapacity 150000 ;
    ho:tagged id:c-multiagent ;
    ho:maturity "draft" .

id:agent-inspection a ho:Agent ;
    skos:prefLabel "Inspection agent (node)" ;
    skos:definition "The inspection node the harness compiles from the inspection role, running in its own session: it perceives the WHOLE design graph and the feedback documents over the agent-user and orchestrator-inspection channels (a WIDE external area) plus its own role and cache (internal area), yet acts narrowly (feedback + git lifecycle) — its function is traceability, keeping a single source of truth. It does NOT observe the internal sessions of the dispatched workers." ;
    ho:agentRole id:role-inspection ;
    ho:agentObservation id:os-inspection ;
    ho:agentFunction id:cap-traceability ;
    ho:cognitiveCapacity 150000 ;
    ho:tagged id:c-multiagent ;
    ho:maturity "draft" .

id:agent-synthesizer a ho:Agent ;
    skos:prefLabel "Synthesizer agent (node)" ;
    skos:definition "The convergence node the harness compiles from the synthesizer role: it perceives every worker's deliverable in the shared file workspace (external area) plus its own role and cache (internal area), and its function is synthesis (cross-checking and compiling the integrated result). It does NOT observe each worker's internal reasoning behind the deliverables it converges." ;
    ho:agentRole id:role-synthesizer ;
    ho:agentObservation id:os-synthesizer ;
    ho:agentFunction id:cap-synthesis ;
    ho:cognitiveCapacity 150000 ;
    ho:tagged id:c-multiagent ;
    ho:maturity "draft" .

########################################################################
# Observation spaces — the per-agent observable envelopes (Omega_i). Each
# agent holds EXACTLY ONE ho:ObservationSpace (via ho:agentObservation): the
# whole envelope of global state it can observe, a partial projection of
# id:global-state (ho:projectsFrom) bounded above by the agent's
# ho:cognitiveCapacity (150000). A space contains its AreasOfInterest (what
# the role WANTS/NEEDS to observe, ho:hasAreaOfInterest) and its
# AreasOfObservation (what is ACTUALLY observed, ho:hasAreaOfObservation);
# ho:unobserved records what the envelope deliberately excludes. Each space
# rolls up to id:h-multiagent through the ho:hasComponent (hasComponent o
# agentObservation) chain, and its areas through the two-hop extensions, so
# each is a connected, orphan-free component (no direct wiring).
########################################################################

#===================== OBSERVATION SPACES ==============================

id:os-orchestrator a ho:ObservationSpace ;
    skos:prefLabel "Orchestrator observation space" ;
    skos:definition "The observable envelope of the orchestrator node: the dispatch/agent-user/orchestrator-inspection channels, the plan and brief documents, and its own role/cache — a partial projection of the system state bounded by its loss-free capacity." ;
    ho:projectsFrom id:global-state ;
    ho:hasAreaOfInterest id:aoi-orchestrator ;
    ho:hasAreaOfObservation id:oa-orchestrator-external, id:oa-orchestrator-internal ;
    ho:unobserved "The execution internals of the workers it dispatches (spawn is opaque; only returned results enter the envelope)." ;
    ho:maturity "draft" .

id:os-developer a ho:ObservationSpace ;
    skos:prefLabel "Developer observation space" ;
    skos:definition "The observable envelope of the developer node: its own dispatch brief, the assigned ontology nodes as a budget-capped retrieval pack, and its own role/cache — a partial projection of the system state bounded by its loss-free capacity." ;
    ho:projectsFrom id:global-state ;
    ho:hasAreaOfInterest id:aoi-developer ;
    ho:hasAreaOfObservation id:oa-developer-external, id:oa-developer-internal ;
    ho:unobserved "Nodes of the graph outside the brief and the internals of other workers." ;
    ho:maturity "draft" .

id:os-vnv a ho:ObservationSpace ;
    skos:prefLabel "Verification observation space" ;
    skos:definition "The observable envelope of the vnv node: the verification-target artifacts, the validator/tool output over the dispatch channel, and its own role/cache — a partial projection of the system state bounded by its loss-free capacity." ;
    ho:projectsFrom id:global-state ;
    ho:hasAreaOfInterest id:aoi-vnv ;
    ho:hasAreaOfObservation id:oa-vnv-external, id:oa-vnv-internal ;
    ho:unobserved "The authoring internals of the components it judges and the internals of other workers." ;
    ho:maturity "draft" .

id:os-inspection a ho:ObservationSpace ;
    skos:prefLabel "Inspection observation space" ;
    skos:definition "The observable envelope of the inspection node: the WHOLE design graph read wide, the feedback documents over the agent-user/orchestrator-inspection channels, and its own role/cache — a deliberately wide projection paired with a narrow action scope, bounded by its loss-free capacity." ;
    ho:projectsFrom id:global-state ;
    ho:hasAreaOfInterest id:aoi-inspection ;
    ho:hasAreaOfObservation id:oa-inspection-external, id:oa-inspection-internal ;
    ho:unobserved "The internal sessions of the dispatched workers." ;
    ho:maturity "draft" .

id:os-synthesizer a ho:ObservationSpace ;
    skos:prefLabel "Synthesizer observation space" ;
    skos:definition "The observable envelope of the synthesizer node: every worker's deliverable in the shared file workspace and its own role/cache — a partial projection of the system state bounded by its loss-free capacity." ;
    ho:projectsFrom id:global-state ;
    ho:hasAreaOfInterest id:aoi-synthesizer ;
    ho:hasAreaOfObservation id:oa-synthesizer-external, id:oa-synthesizer-internal ;
    ho:unobserved "Each worker's internal reasoning behind the deliverables it converges." ;
    ho:maturity "draft" .

########################################################################
# Areas of interest — the per-agent information requirements (intent).
# Each is a target the role NEEDS/WANTS to observe, independent of whether
# it is realized; the realized AreaOfObservation ho:coversInterest it. No
# ho:tokenEstimate: an interest is intent, not consumed input.
########################################################################

#===================== AREAS OF INTEREST ===============================

id:aoi-orchestrator a ho:AreaOfInterest ;
    skos:prefLabel "Orchestrator area of interest" ;
    skos:definition "What the orchestrator role NEEDS to observe: the workers' returned results and the current plan/brief state, so it can plan the next dispatch." ;
    ho:observationKind "external" ;
    ho:maturity "draft" .

id:aoi-developer a ho:AreaOfInterest ;
    skos:prefLabel "Developer area of interest" ;
    skos:definition "What the developer role NEEDS to observe: its dispatch brief and the specific ontology nodes assigned to it, sufficient to author the assigned individuals correctly." ;
    ho:observationKind "external" ;
    ho:maturity "draft" .

id:aoi-vnv a ho:AreaOfInterest ;
    skos:prefLabel "Verification area of interest" ;
    skos:definition "What the vnv role NEEDS to observe: the composition artifacts under verification and the authoritative validator/tool output, sufficient to render a verdict." ;
    ho:observationKind "external" ;
    ho:maturity "draft" .

id:aoi-inspection a ho:AreaOfInterest ;
    skos:prefLabel "Inspection area of interest" ;
    skos:definition "What the inspection role NEEDS to observe: the whole design graph and the feedback documents, sufficient to trace change ripple and keep a single source of truth." ;
    ho:observationKind "external" ;
    ho:maturity "draft" .

id:aoi-synthesizer a ho:AreaOfInterest ;
    skos:prefLabel "Synthesizer area of interest" ;
    skos:definition "What the synthesizer role NEEDS to observe: every worker's deliverable in the shared workspace, sufficient to cross-check and compile the integrated final result." ;
    ho:observationKind "external" ;
    ho:maturity "draft" .

########################################################################
# Areas of observation — what each agent ACTUALLY observes in one
# inference (realized input data). Each agent holds an EXTERNAL area
# (observing beyond its components: channels via ho:observesChannel, the
# file read-boundary via ho:observedFileScope, the firmware+long-term memory
# tiers) and an INTERNAL area (introspection over its own Role via
# ho:observesComponent and its cache memory). ho:tokenEstimate records the
# realized size each area contributes; the per-agent sum stays far under
# ho:cognitiveCapacity (150000). The external area ho:coversInterest the
# agent's AreaOfInterest (realized meets intended). These areas roll up to
# id:h-multiagent through the two-hop hasComponent chain (hasComponent o
# agentObservation o hasAreaOfObservation), so each is orphan-free.
########################################################################

#===================== AREAS OF OBSERVATION ============================

id:oa-orchestrator-external a ho:AreaOfObservation ;
    skos:prefLabel "Orchestrator external observation" ;
    skos:definition "What the orchestrator perceives beyond itself: the dispatch, agent-user and orchestrator-inspection channels it reads, and the plan/brief documents it plans from." ;
    ho:observationKind "external" ;
    ho:coversInterest id:aoi-orchestrator ;
    ho:observesChannel id:chan-dispatch, id:chan-agent-user, id:chan-orchestrator-inspection ;
    ho:observedFileScope "docs/plans/** and docs/feedback/** (plan and brief documents, read)" ;
    ho:observesMemory id:mem-firmware, id:mem-longterm ;
    ho:unobserved "The execution internals of the workers it dispatches (spawn is opaque; only returned results are perceived)." ;
    ho:tokenEstimate 9000 ; ho:maturity "draft" .

id:oa-orchestrator-internal a ho:AreaOfObservation ;
    skos:prefLabel "Orchestrator internal observation" ;
    skos:definition "The orchestrator's introspection over its own constituent parts: its role (mandate/policy) and its task-scoped cache memory holding the plan state." ;
    ho:observationKind "internal" ;
    ho:observesComponent id:role-orchestrator ;
    ho:observesMemory id:mem-cache ;
    ho:unobserved "Any component of another agent (only its own parts are introspected)." ;
    ho:tokenEstimate 2000 ; ho:maturity "draft" .

id:oa-developer-external a ho:AreaOfObservation ;
    skos:prefLabel "Developer external observation" ;
    skos:definition "What the developer perceives beyond itself: its own dispatch brief over the dispatch channel and the assigned ontology nodes retrieved as a budget-capped pack (never the whole store)." ;
    ho:observationKind "external" ;
    ho:coversInterest id:aoi-developer ;
    ho:observesChannel id:chan-dispatch ;
    ho:observedFileScope "The assigned brief and only the assigned ontology/abox nodes, as a budget-capped retrieval pack" ;
    ho:observesMemory id:mem-firmware, id:mem-longterm ;
    ho:unobserved "Nodes of the graph outside the brief and the internals of other workers." ;
    ho:tokenEstimate 6000 ; ho:maturity "draft" .

id:oa-developer-internal a ho:AreaOfObservation ;
    skos:prefLabel "Developer internal observation" ;
    skos:definition "The developer's introspection over its own constituent parts: its role and its task-scoped cache memory." ;
    ho:observationKind "internal" ;
    ho:observesComponent id:role-developer ;
    ho:observesMemory id:mem-cache ;
    ho:unobserved "Any component of another agent." ;
    ho:tokenEstimate 1500 ; ho:maturity "draft" .

id:oa-vnv-external a ho:AreaOfObservation ;
    skos:prefLabel "Verification external observation" ;
    skos:definition "What the vnv agent perceives beyond itself: the verification-target artifacts handed to it over the dispatch channel and the validator/tool output it evaluates." ;
    ho:observationKind "external" ;
    ho:coversInterest id:aoi-vnv ;
    ho:observesChannel id:chan-dispatch ;
    ho:observedFileScope "The composition artifacts under verification and the validate.py/tool output, read" ;
    ho:observesMemory id:mem-firmware, id:mem-longterm ;
    ho:unobserved "The authoring internals of the components it judges and the internals of other workers." ;
    ho:tokenEstimate 5000 ; ho:maturity "draft" .

id:oa-vnv-internal a ho:AreaOfObservation ;
    skos:prefLabel "Verification internal observation" ;
    skos:definition "The vnv agent's introspection over its own constituent parts: its role and its task-scoped cache memory." ;
    ho:observationKind "internal" ;
    ho:observesComponent id:role-vnv ;
    ho:observesMemory id:mem-cache ;
    ho:unobserved "Any component of another agent." ;
    ho:tokenEstimate 1500 ; ho:maturity "draft" .

id:oa-inspection-external a ho:AreaOfObservation ;
    skos:prefLabel "Inspection external observation" ;
    skos:definition "What the inspection agent perceives beyond itself: the WHOLE design graph read wide, plus the feedback documents over the agent-user and orchestrator-inspection channels. A deliberately wide perception paired with a narrow action scope." ;
    ho:observationKind "external" ;
    ho:coversInterest id:aoi-inspection ;
    ho:observesChannel id:chan-agent-user, id:chan-orchestrator-inspection ;
    ho:observedFileScope "The whole design graph (ontology/** and docs/**) read, plus docs/feedback/** " ;
    ho:observesMemory id:mem-firmware, id:mem-longterm ;
    ho:unobserved "The internal sessions of the dispatched workers." ;
    ho:tokenEstimate 12000 ; ho:maturity "draft" .

id:oa-inspection-internal a ho:AreaOfObservation ;
    skos:prefLabel "Inspection internal observation" ;
    skos:definition "The inspection agent's introspection over its own constituent parts: its role and its session cache memory." ;
    ho:observationKind "internal" ;
    ho:observesComponent id:role-inspection ;
    ho:observesMemory id:mem-cache ;
    ho:unobserved "Any component of another agent." ;
    ho:tokenEstimate 1500 ; ho:maturity "draft" .

id:oa-synthesizer-external a ho:AreaOfObservation ;
    skos:prefLabel "Synthesizer external observation" ;
    skos:definition "What the synthesizer perceives beyond itself: every worker's deliverable in the shared file workspace, picked up from one place for cross-check and integration." ;
    ho:observationKind "external" ;
    ho:coversInterest id:aoi-synthesizer ;
    ho:observesChannel id:chan-workspace ;
    ho:observedFileScope "All worker deliverable artifacts in the shared workspace directory, read" ;
    ho:observesMemory id:mem-firmware, id:mem-longterm ;
    ho:unobserved "Each worker's internal reasoning behind the deliverables it converges." ;
    ho:tokenEstimate 8000 ; ho:maturity "draft" .

id:oa-synthesizer-internal a ho:AreaOfObservation ;
    skos:prefLabel "Synthesizer internal observation" ;
    skos:definition "The synthesizer's introspection over its own constituent parts: its role and its task-scoped cache memory." ;
    ho:observationKind "internal" ;
    ho:observesComponent id:role-synthesizer ;
    ho:observesMemory id:mem-cache ;
    ho:unobserved "Any component of another agent." ;
    ho:tokenEstimate 1500 ; ho:maturity "draft" .
