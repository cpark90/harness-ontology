@prefix ho:    <https://harness-ontology.dev/schema#> .
@prefix id:    <https://harness-ontology.dev/id/core/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .

# Core data unit -- Workflow partition of the `core` domain. Imports the
# central TBox only; cross-unit references resolve in the root union
# (docs/federation-design.md D1, ONTOLOGYSTYLE 4).
<https://harness-ontology.dev/data/core/workflows> a owl:Ontology ;
    owl:imports <https://harness-ontology.dev/schema> .

#===================== Workflows =======================================
id:wf-react a ho:Workflow ; skos:prefLabel "ReAct loop" ;
    ho:dependsOn id:tool-shell ; ho:tokenEstimate 60 ; ho:maturity "stable" ; ho:tagged id:c-autonomy .
id:wf-planexec a ho:Workflow ; skos:prefLabel "Plan-execute loop" ;
    ho:dependsOn id:tool-retriever ; ho:tokenEstimate 65 ; ho:maturity "reviewed" .
id:wf-singleshot a ho:Workflow ; skos:prefLabel "Single-shot" ;
    ho:tokenEstimate 20 ; ho:maturity "stable" .
id:wf-multiagent a ho:Workflow ; skos:prefLabel "Multi-agent orchestration loop" ;
    skos:definition "Orchestrator plans and dispatches node-scoped briefs to worker agents that author, verify and inspect, then integrates and gates the results; separates authoring, judgment and application. Choose for work that must stay traceable across specialised roles." ;
    ho:providesCapability id:cap-orchestration ;
    ho:derivedFrom id:wf-planexec ;
    ho:tagged id:c-multiagent, id:c-design ; ho:tokenEstimate 74 ; ho:maturity "reviewed" .
id:wf-compose-harness a ho:Workflow ; skos:prefLabel "Harness composition" ;
    skos:definition "Assemble a new harness out of the ontology's reusable, typed parts: (1) retrieve a budget-capped context pack for the request; (2) take the top base-harness candidate as a template, or a DesignPattern when none fits; (3) bind every requiresCapability in scope to a component that providesCapability it, filling each capability gap by reusing an existing part or authoring a new one; (4) assemble the HarnessShape minimums -- one SystemPrompt, at least one Workflow, tools, guardrails and one ModelConfig; (5) write it back as new individuals carrying prefLabel, maturity draft, derivedFrom the template, tokenEstimate on every node with text, and existing Concept tags; (6) run validate.py for connectivity, typing and capability satisfaction; (7) pass the coverage-audit gate that maps every source element to a representation; then materialize -- the ODR EMIT axis renders the validated spec into artifacts. Choose when building a harness by selecting and wiring existing parts rather than authoring one from scratch." ;
    ho:tagged id:c-composition ; ho:tokenEstimate 205 ; ho:maturity "reviewed" .
