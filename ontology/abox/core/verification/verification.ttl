@prefix ho:    <https://harness-ontology.dev/schema#> .
@prefix id:    <https://harness-ontology.dev/id/core/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .

# Core data unit -- Verification partition of the `core` domain (relocated out
# of the workflows unit, where these leaves were co-located while this unit did
# not exist). Imports the central TBox only; cross-unit references (each
# scenario's ho:scenarioReferences step of the verification workflow, the
# harness binding these via ho:hasTestScenario / ho:hasFailurePolicy) resolve in
# the root union (docs/federation-design.md D1, ONTOLOGYSTYLE 4).
<https://harness-ontology.dev/data/core/verification> a owl:Ontology ;
    owl:imports <https://harness-ontology.dev/schema> .

########################################################################
# Run-time acceptance parts — the behaviour fixtures (ho:TestScenario) and
# error-handling rows (ho:FailurePolicy) that judge a harness while it RUNS,
# as opposed to the structural gate that judges its assembled shape. Neutral:
# they name no problem domain, tool or technology. Bound to a harness by
# ho:hasTestScenario / ho:hasFailurePolicy (direct sub-properties of
# ho:hasComponent), which is what keeps them connected.
########################################################################

#===================== Test scenarios ==================================
id:scn-compose-smoke a ho:TestScenario ;
    skos:prefLabel "Compose smoke scenario" ;
    skos:definition "The happy-path acceptance fixture of a composing harness: it pins what a representative compose request must actually PRODUCE, so a run that merely completed is never mistaken for one that produced a usable harness. Choose as the minimum behaviour gate to clear before any richer scenario is worth writing." ;
    ho:scenarioReferences id:wfs-structure-check ;
    ho:scenarioKind "normal" ;
    ho:scenarioPrompt "Compose a harness for a representative request out of the existing parts." ;
    ho:scenarioExpected "The assembled harness carries the required minimums: one system prompt, at least one workflow, at least one tool, at least one guardrail and one model configuration." ,
        "Every capability the harness requires is provided by one of its own bound components -- no capability gap is left open." ,
        "The structural validation gate passes, with no orphaned node and no untyped edge." ;
    ho:tokenEstimate 120 ; ho:maturity "draft" .

id:scn-trigger-near-miss a ho:TestScenario ;
    skos:prefLabel "Trigger near-miss scenario" ;
    skos:definition "The negative half of activation testing: a request that resembles the harness's stated purpose but falls outside it, which must NOT activate it. Choose because positive triggers alone cannot distinguish a well-scoped description from one so broad that it fires on everything." ;
    ho:scenarioReferences id:wfs-trigger-validation ;
    ho:scenarioKind "trigger-negative" ;
    ho:scenarioPrompt "Issue a request that is superficially similar to the harness's stated purpose but lies outside its declared scope." ;
    ho:scenarioExpected "The harness does not activate and no worker is dispatched for the out-of-scope request." ,
        "The out-of-scope condition is stated back rather than reinterpreted into an in-scope task." ;
    ho:tokenEstimate 105 ; ho:maturity "draft" .

#===================== Failure policies ================================
id:fp-dispatch-timeout a ho:FailurePolicy ;
    skos:prefLabel "Dispatched worker does not return" ;
    skos:definition "Makes the commonest multi-agent failure an explicit, pre-decided row instead of prose: without it a dispatch that never returns either hangs the run or is silently counted as complete. Choose for any harness that delegates work it cannot itself observe." ;
    ho:failureCondition "A dispatched worker returns no result within the run's give-up bound." ;
    ho:recoveryStrategy "Re-dispatch the same brief once, then stop: report a clearly flagged partial that names the scope still missing, rather than waiting longer or assuming the work was done." ;
    ho:tokenEstimate 95 ; ho:maturity "draft" .

id:fp-validation-fail a ho:FailurePolicy ;
    skos:prefLabel "Validation gate fails after a change" ;
    skos:definition "Fixes in advance what a failing gate means, because the tempting recovery -- relaxing the check until it passes -- is exactly the move that erodes every structural guarantee the gate exists to hold. Choose for any harness whose output is admitted by an automated gate." ;
    ho:failureCondition "The validation gate rejects an authored change: a shape violation, an orphaned node or an unsatisfied capability." ;
    ho:recoveryStrategy "Do not admit the change; return it to the authoring step with the failing check named and repair the model, never weaken the check to make it pass." ;
    ho:tokenEstimate 100 ; ho:maturity "draft" .

#===================== Failure policies (neutral archetypes) ===========
# The error rows a delegating, document-producing team declares regardless of
# its problem domain: a worker that fails, an input too thin to work from, a
# critical review finding, an unreachable source, and two deliverables that
# contradict each other. They are generalised archetypes, siblings of the two
# methodology-specific rows above -- each says how it differs from the nearest
# one so the set stays discriminating rather than overlapping.

id:fp-agent-failure-retry a ho:FailurePolicy ;
    skos:prefLabel "Dispatched worker fails its task" ;
    skos:definition "The row a delegating team needs most often: the worker does come back, and what it brings back is a failure. Choose it for any harness that hands work to units it cannot supervise, so a failed unit is retried once under the same brief and then bounded, instead of being retried without limit or dropped without trace. Distinguished from id:fp-dispatch-timeout, whose condition is SILENCE -- here the worker reports, and the report is failure." ;
    ho:failureCondition "A dispatched worker returns having failed its assignment: it reports an error or an unusable result instead of the requested deliverable." ;
    ho:recoveryStrategy "Retry the same assignment once; if it fails again, continue the run without that unit of work and mark the gap explicitly in the final deliverable, so the missing scope is visible rather than silently absent." ;
    ho:tokenEstimate 150 ; ho:maturity "draft" .

id:fp-insufficient-input a ho:FailurePolicy ;
    skos:prefLabel "Input too thin to determine the deliverable" ;
    skos:definition "Pre-decides the commonest quality trap of a request-driven team: a role handed too little either stalls waiting for more or quietly invents the missing context and presents it as given. Choose it for any harness whose first step consumes a brief supplied by someone outside the team." ;
    ho:failureCondition "The input a step depends on is missing, ambiguous or too thin to determine what the deliverable should be." ;
    ho:recoveryStrategy "Proceed on stated general defaults rather than stopping, and mark every place a default stood in for real input as needing confirmation, so the deliverable stays usable while its assumptions stay visible and correctable." ;
    ho:tokenEstimate 115 ; ho:maturity "draft" .

id:fp-review-critical-rework a ho:FailurePolicy ;
    skos:prefLabel "Review raises a critical finding" ;
    skos:definition "Fixes in advance what the top severity band actually costs, because deciding that in the moment is what turns a review loop either unbounded or toothless. Choose it together with the cross-validation guardrail: without a bound, a critical finding either reopens the work indefinitely or is quietly downgraded to fit the schedule." ;
    ho:failureCondition "Cross-validation raises a finding in the top severity band against a deliverable." ;
    ho:recoveryStrategy "Return the deliverable to the role that produced it for rework, at most twice; if the finding survives, escalate it and ship the deliverable as a clearly flagged partial rather than looping further." ;
    ho:tokenEstimate 112 ; ho:maturity "draft" .

id:fp-source-unavailable a ho:FailurePolicy ;
    skos:prefLabel "A depended-on source cannot be reached" ;
    skos:definition "Keeps an unreachable external source from becoming either a hard stop or an invisible fabrication -- the two ways a grounded deliverable normally degrades. Choose it for any harness whose output rests on evidence the team does not itself hold." ;
    ho:failureCondition "An external source the work depends on cannot be reached, or returns nothing usable." ;
    ho:recoveryStrategy "Fall back to the best available substitute evidence and state in the deliverable which claim rests on the substitute and what could not be reached, rather than dropping the claim or presenting it as fully grounded." ;
    ho:tokenEstimate 105 ; ho:maturity "draft" .

id:fp-conflict-contradiction a ho:FailurePolicy ;
    skos:prefLabel "Deliverables contradict each other" ;
    skos:definition "Names in advance who resolves a contradiction between two roles' outputs and on what basis. Choose it for any harness whose deliverables are produced in parallel and merged afterwards: without this row the contradiction is settled by whichever text the merging step happens to read last." ;
    ho:failureCondition "Two deliverables that must be merged state incompatible facts or incompatible recommendations." ;
    ho:recoveryStrategy "Do not silently keep one: have the reviewing role state both positions, name the direction of resolution with the reason for it, and record the discarded position so the choice stays traceable." ;
    ho:tokenEstimate 105 ; ho:maturity "draft" .
