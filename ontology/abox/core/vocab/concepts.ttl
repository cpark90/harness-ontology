@prefix ho:    <https://harness-ontology.dev/schema#> .
@prefix id:    <https://harness-ontology.dev/id/core/> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .

# Core data unit -- Concept + ConceptScheme partition of the `core` domain. This is the
# terminology (glossary) layer: every Concept is a defined term (prefLabel + definition),
# not a bare tag. Imports the central TBox only; cross-unit references resolve in the root
# union (docs/federation-design.md D1, ONTOLOGYSTYLE 4).
<https://harness-ontology.dev/data/core/concepts> a owl:Ontology ;
    owl:imports <https://harness-ontology.dev/schema> .

#===================== Subject-matter concepts (what a harness is about) ====
id:c-softeng a ho:Concept ;
    skos:prefLabel "Software engineering" ;
    skos:definition "The practice of building, modifying and maintaining software systems; tag harnesses and components whose subject matter is code authorship and engineering work." ;
    skos:topConceptOf id:scheme .
id:c-debugging a ho:Concept ;
    skos:prefLabel "Debugging" ;
    skos:definition "The activity of locating and fixing defects in existing software; tag harnesses focused on diagnosis and repair rather than greenfield authorship." ;
    skos:broader id:c-softeng .
id:c-inforetrieval a ho:Concept ;
    skos:prefLabel "Information retrieval" ;
    skos:definition "Finding and surfacing relevant information from a corpus or knowledge store; tag harnesses and tools whose core job is search and retrieval." ;
    skos:topConceptOf id:scheme .
id:c-summarization a ho:Concept ;
    skos:prefLabel "Summarization" ;
    skos:definition "Condensing source material into a shorter faithful rendering; tag components that compress or abstract retrieved content." ;
    skos:broader id:c-inforetrieval .
id:c-safety a ho:Concept ;
    skos:prefLabel "Safety" ;
    skos:definition "Avoidance of harmful, irreversible or unsafe actions; tag guardrails and components whose purpose is to keep agent behaviour within safe bounds." ;
    skos:topConceptOf id:scheme .
id:c-autonomy a ho:Concept ;
    skos:prefLabel "Autonomy" ;
    skos:definition "The degree to which an agent acts without human intervention; tag harnesses whose design turns on how much independent initiative the agent is granted." ;
    skos:related id:c-safety .
id:c-communication a ho:Concept ;
    skos:prefLabel "Communication" ;
    skos:definition "How agents and users exchange information and status; tag components governing message form, channels and reporting discipline." ;
    skos:topConceptOf id:scheme .
id:c-design a ho:Concept ;
    skos:prefLabel "Design methodology" ;
    skos:definition "Principles for structuring a system or solution well; tag components that encode engineering-design discipline such as simplicity and root-cause reasoning." ;
    skos:topConceptOf id:scheme .
id:c-multiagent a ho:Concept ;
    skos:prefLabel "Multi-agent orchestration" ;
    skos:definition "Coordinating multiple specialised agents toward one goal; tag harnesses and principles about role division, dispatch and delegation." ;
    skos:topConceptOf id:scheme ; skos:related id:c-autonomy .
id:c-memory a ho:Concept ;
    skos:prefLabel "Agent memory" ;
    skos:definition "The memory architecture an agent maintains -- the firmware/cache/long-term tiers distinguished by read-timing and persistence." ;
    skos:topConceptOf id:scheme ; skos:related id:c-autonomy .
id:c-traceability a ho:Concept ;
    skos:prefLabel "Traceability" ;
    skos:definition "Keeping every decision and artifact linked to its source and history; tag components that enforce provenance, non-deletion and grounded records." ;
    skos:topConceptOf id:scheme .

#===================== Governance methodology (cross-cutting principles) =====
# Each term below is the *principle* a governance guardrail enforces, kept distinct from
# the enforceable Guardrail rule itself (concept = the defined idea, guardrail = the policy
# that applies it). Domain-specific principles hang under an existing top (safety/design/
# communication/traceability/multi-agent); the remaining operational disciplines hang under
# the methodology top concept. Every term is connected via skos:broader + guardrail tags.
id:c-agent-methodology a ho:Concept ;
    skos:prefLabel "Agent governance methodology" ;
    skos:altLabel "operational discipline" ;
    skos:definition "Cross-cutting operational disciplines that govern how an agent or multi-agent harness conducts its work, independent of the task domain; the parent term for principles like least privilege, verify-then-proceed and design-for-loss." ;
    skos:topConceptOf id:scheme .

id:c-least-privilege a ho:Concept ;
    skos:prefLabel "Least privilege" ;
    skos:altLabel "separation of duties" ;
    skos:definition "The principle that each role edits only its own responsibility boundary and holds the minimum permissions needed, keeping authoring, judgment, application and version control in separate hands." ;
    skos:broader id:c-agent-methodology .
id:c-verify-proceed a ho:Concept ;
    skos:prefLabel "Verify then proceed" ;
    skos:altLabel "no time assumptions" ;
    skos:definition "The principle of advancing only on confirmed state rather than assuming readiness from elapsed time, treating timeouts as give-up bounds and not as correctness premises." ;
    skos:broader id:c-agent-methodology .
id:c-design-for-loss a ho:Concept ;
    skos:prefLabel "Design for loss" ;
    skos:definition "The principle of treating message and data loss as a normal event -- judging completion by the receiver's confirmation, holding custody until the next stage confirms receipt, and making every loss observable." ;
    skos:broader id:c-agent-methodology .
id:c-escalation a ho:Concept ;
    skos:prefLabel "Escalate open decisions" ;
    skos:altLabel "no arbitrary decisions" ;
    skos:definition "The principle of never resolving an undecided question alone but registering each open judgment as an issue and escalating it to the decision authority." ;
    skos:broader id:c-agent-methodology .
id:c-bounded-context a ho:Concept ;
    skos:prefLabel "Bounded context projection" ;
    skos:altLabel "anti-context-rot" ;
    skos:definition "The principle of never ingesting the whole knowledge store but retrieving only a request-scoped, budget-capped projection, keeping the working context bounded to defend against context rot." ;
    skos:broader id:c-agent-methodology .
id:c-graceful-fallback a ho:Concept ;
    skos:prefLabel "Graceful fallback" ;
    skos:altLabel "error fallback" ;
    skos:definition "The principle of anticipating failure per operation and degrading gracefully -- defining a fallback (retry, reduced-scope result or a flagged partial) for each foreseeable failure mode instead of aborting the whole run, and making any degradation explicit." ;
    skos:broader id:c-agent-methodology .
id:c-composition a ho:Concept ;
    skos:prefLabel "Harness composition" ;
    skos:altLabel "assembly from parts" ;
    skos:definition "The practice of assembling a harness from reusable ontology parts -- selecting a base template or pattern, binding required capabilities to providers and satisfying the harness shape -- rather than authoring one from scratch; tag components that encode the composition process." ;
    skos:broader id:c-agent-methodology .
id:c-reuse-first a ho:Concept ;
    skos:prefLabel "Reuse-first authoring" ;
    skos:altLabel "anti-orphan authoring discipline" ;
    skos:definition "The discipline of reusing an existing typed part before authoring a new one, and connecting any new part in the same change (a broader parent, a tag or a provider) so the graph never gains an orphan; tag components that enforce reuse-first, anti-drift, anti-orphan authoring." ;
    skos:broader id:c-agent-methodology .
id:c-skill-authoring a ho:Concept ;
    skos:prefLabel "Skill authoring" ;
    skos:altLabel "well-formed skill packaging" ;
    skos:definition "The principle of authoring and packaging an agent skill in well-formed shape -- a present description, the required section headings and no forbidden files -- so it is discoverable, invocable and contract-checkable; tag the capability and guardrail that govern how a skill is written." ;
    skos:broader id:c-agent-methodology .
id:c-acceptance-coverage a ho:Concept ;
    skos:prefLabel "Acceptance coverage" ;
    skos:altLabel "three-flow fixtures" ;
    skos:definition "The principle that behaviour fixtures must cover the normal flow, the flow resumed over existing input and the error flow rather than the happy path alone, so a run that merely completed is never mistaken for one that was accepted; tag the components that fix how much behaviour a harness must demonstrate before it counts as done." ;
    skos:broader id:c-agent-methodology .

id:c-root-cause a ho:Concept ;
    skos:prefLabel "Root-cause resolution" ;
    skos:definition "The principle of resolving problems at their underlying cause rather than masking a symptom with a guard that leaves the fault in place." ;
    skos:broader id:c-design .
id:c-simplicity a ho:Concept ;
    skos:prefLabel "Simplicity" ;
    skos:altLabel "YAGNI" ;
    skos:definition "The principle of preferring the simplest form that works, removing branches rather than adding them and avoiding speculative generalization that nothing uses yet." ;
    skos:broader id:c-design .

id:c-report-over-prompt a ho:Concept ;
    skos:prefLabel "Report over prompt" ;
    skos:definition "The principle of writing status, decisions, questions and reports to durable channels rather than volatile chat, leaving only a one-line pointer to where each was written." ;
    skos:broader id:c-communication .
id:c-controlled-vocabulary a ho:Concept ;
    skos:prefLabel "Controlled vocabulary" ;
    skos:altLabel "anti-drift" ;
    skos:definition "The principle of reusing registered terms and established domain vocabulary rather than coining near-synonyms or private abbreviations, adding new terms to a single terminology source." ;
    skos:broader id:c-communication .
id:c-structured-output a ho:Concept ;
    skos:prefLabel "Structured output" ;
    skos:altLabel "deliverable template" ;
    skos:definition "The principle of emitting each deliverable in a consistent, agreed structured template so downstream roles and convergence gates can consume it mechanically rather than re-parsing free-form prose." ;
    skos:broader id:c-communication .

id:c-grounding a ho:Concept ;
    skos:prefLabel "Grounding" ;
    skos:definition "The principle of linking every derived artifact or claim to its originating decision, rationale or source rather than restating another document." ;
    skos:broader id:c-traceability .
id:c-structural-coverage a ho:Concept ;
    skos:prefLabel "Structural coverage" ;
    skos:altLabel "source-fidelity reflection" ;
    skos:definition "The principle of exhaustively mapping every structural element of a source into the model, extending the schema for anything unrepresented rather than silently skipping it." ;
    skos:broader id:c-traceability .

id:c-dispatch a ho:Concept ;
    skos:prefLabel "Dispatch-based execution" ;
    skos:altLabel "no standalone workers" ;
    skos:definition "The principle that worker agents act only when dispatched by the orchestrator and are never run standalone or invoked directly outside a dispatch." ;
    skos:broader id:c-multiagent .
id:c-delegation a ho:Concept ;
    skos:prefLabel "Delegated orchestration" ;
    skos:altLabel "orchestrator does not work directly" ;
    skos:definition "The principle that the user-facing orchestrator does no substantive work directly but only plans and dispatches, with all execution flowing through the worker agents." ;
    skos:broader id:c-multiagent .
id:c-synthesis a ho:Concept ;
    skos:prefLabel "Synthesis" ;
    skos:altLabel "convergence gate" ;
    skos:definition "The principle of converging the separate deliverables of multiple worker roles into one coherent, cross-checked final result -- the terminal convergence step of a multi-agent workflow, distinct from mere verification in that it also compiles the integrated output." ;
    skos:broader id:c-multiagent .
id:c-scale-modes a ho:Concept ;
    skos:prefLabel "Scale execution modes" ;
    skos:altLabel "full/reduced/single modes" ;
    skos:definition "The principle of matching effort to request scope by scaling the active agent roles and workflow -- a full team for a broad request, a reduced subset for a narrow one, a single pass for a trivial one -- rather than always running the whole team." ;
    skos:broader id:c-multiagent .
id:c-execution-mode a ho:Concept ;
    skos:prefLabel "Execution mode" ;
    skos:altLabel "runtime coordination topology" ;
    skos:definition "The runtime topology a multi-agent harness coordinates in -- peer agent-teams, lightweight sub-agents, or a phase-varying hybrid -- an axis orthogonal to the architectural data-flow pattern; tags the ho:ExecutionMode individuals a harness selects from via ho:hasExecutionMode (and the DesignPatterns they superseded)." ;
    skos:broader id:c-multiagent .
id:c-pattern-taxonomy a ho:Concept ;
    skos:prefLabel "Coordination pattern taxonomy" ;
    skos:altLabel "architectural multi-agent patterns" ;
    skos:definition "The catalogue of architectural multi-agent coordination patterns -- how work flows and is structured across agents (pipeline, fan-out/fan-in, expert pool, producer-reviewer, supervisor, hierarchical delegation) -- independent of the runtime execution mode; tag the DesignPatterns describing agent work-flow architecture." ;
    skos:broader id:c-multiagent .
id:c-complexity-governance a ho:Concept ;
    skos:prefLabel "Complexity governance" ;
    skos:altLabel "orchestration complexity limits" ;
    skos:definition "The principle of bounding multi-agent orchestration complexity -- limiting delegation depth, forbidding nested teams, keeping a single active team, avoiding coordination bottlenecks and flattening hierarchy -- so a harness stays tractable and debuggable rather than sprawling; tag guardrails that cap structural complexity." ;
    skos:broader id:c-multiagent .
id:c-cross-validation a ho:Concept ;
    skos:prefLabel "Cross-validation" ;
    skos:altLabel "severity-triaged peer review" ;
    skos:definition "The principle that a deliverable is checked by a role other than the one that produced it and that each finding is graded by severity, only the top band forcing rework -- the review discipline that keeps a producer-reviewer loop convergent instead of letting every remark reopen the work. Distinct from synthesis, which merges the reviewed contributions into the final result." ;
    skos:broader id:c-multiagent .
id:c-deliverable-artifact a ho:Concept ;
    skos:prefLabel "Deliverable artifact" ;
    skos:altLabel "workspace artifact naming" ;
    skos:definition "The named file a role writes into the shared workspace as its unit of hand-off, together with the naming discipline (ordinal prefix, document type, extension) that makes production order readable and lets a consumer resolve exactly which artifact a producer wrote; tag the components that govern how hand-off artifacts are named and ordered." ;
    skos:broader id:c-multiagent .

#===================== Concept scheme ==================================
id:scheme a skos:ConceptScheme ; skos:prefLabel "Harness ontology vocabulary" .
